#fs-brand{text-align:center;font-size:8px;letter-spacing:.18em;text-transform:uppercase;color:#c8c3bc;padding:7px 0 5px;border-top:0.5px solid #e8e5e0;background:#fafaf8}
#fs-bubble{width:56px;height:56px;border-radius:50%;background:#0a0a0a;border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:transform .3s,background .3s;flex-shrink:0}
#fs-bubble:hover{transform:scale(1.06);background:#1a1a1a}
#fs-bubble-label{font-size:8px;letter-spacing:.16em;text-transform:uppercase;color:#9a9590;text-align:center}
</style>
