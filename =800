.fs-divider{height:1px;background:linear-gradient(90deg,transparent,#b8976a 30%,#b8976a 70%,transparent);opacity:.4}
#fs-messages{overflow-y:auto;padding:18px;display:flex;flex-direction:column;gap:14px;min-height:260px;max-height:320px;background:#fafaf8}
