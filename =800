    function buildProductCard(item, query, matchType) {
        var nameHtml = (query && matchType === 'name')
            ? getHighlightedText(item.name, query, matchType)
            : escapeHtml(item.name);

        return '<a class="search-product-card no-underline" href="/' + escapeHtml(item.sku) + '.html">' +
            '<div class="search-product-img-wrap">' +
            '<img class="search-product-img" src="' + escapeHtml(item.image) + '" alt="' + escapeHtml(item.name) + '" loading="eager" decoding="sync" onerror="this.src=\'https://placehold.co/400x533/f9fafb/a1a1aa?text=No+Image\'">' +
            '</div>' +
            '<div class="search-product-name no-underline">' + nameHtml + '</div>' +
            '<div class="search-product-sku no-underline">' + escapeHtml(item.sku) + '</div>' +
            '<div class="search-product-price no-underline">' + escapeHtml(item.price) + '</div>' +
            '</a>';
    }

    /* ═══ EMPTY STATE: Category pills + recently viewed ═══ */
    function showDefaultState() {
        $('#search-filled-state').prop('hidden', true);
        $('#search-loading').prop('hidden', true);
        $('#search-empty-state').prop('hidden', false);

        /* Category pills */
        var cats = getUniqueCategories();
        var pillsHtml = '';
        $.each(cats, function (i, cat) {
            pillsHtml += '<a class="search-pill no-underline" href="#" data-category="' + escapeHtml(cat.label) + '">' +
                '<span>' + escapeHtml(cat.label) + '</span></a>';
        });
        $('#search-category-pills').html(pillsHtml);

        /* 4 recently viewed products */
        var gridHtml = '';
        $.each(recentlyViewed, function (i, item) {
            gridHtml += buildProductCard(item, null, null);
        });
        $('#search-recently-grid').html(gridHtml);
    }

    /* ═══ FILLED STATE: Suggestions + Results ═══ */
    function renderSearchResults(query) {
        var searchUrl = $('#search_form').attr('action');
        var queryParamName = 'q';

        $('#search-loading').prop('hidden', true);

        /* Switch to filled state */
        $('#search-empty-state').prop('hidden', true);
        $('#search-filled-state').prop('hidden', false);

        if ($.trim(query)) {
            $('#search-input-clear').addClass('visible');
        } else {
            $('#search-input-clear').removeClass('visible');
        }

        /* ─── Suggestion pills from top matches ─── */
        var suggestions = generateSuggestions(query);
        var suggestHtml = '';
        $.each(suggestions, function (i, label) {
            suggestHtml += '<a class="search-pill no-underline" href="#" data-suggest="' + escapeHtml(label) + '">' +
                '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="width:14px;height:14px"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>' +
                '<span>' + escapeHtml(label) + '</span></a>';
        });
        $('#search-suggest-pills').html(suggestHtml);
        $('#search-suggest-section').prop('hidden', !suggestHtml);

        /* ─── Scoring Engine ─── */
        var result = handleSearch(query);

        /* ─── ZERO-RESULT: Fallback ─── */
        if (result.isFallback) {
            $('#search-products-section').prop('hidden', true);
            var zeroHtml = '';
            $.each(result.items, function (i, entry) {
                zeroHtml += buildProductCard(entry.product, null, 'fallback');
            });
            $('#search-zero-result .search-zero-msg').text(
                'Không tìm thấy sản phẩm phù hợp. Có thể bạn sẽ thích:'
            );
            $('#search-zero-grid').html(zeroHtml);
            $('#search-zero-result').prop('hidden', false);

            var viewAllUrl0 = searchUrl + '?' + encodeURIComponent(queryParamName) + '=' + encodeURIComponent(query);
            $('#search-view-all-btn').attr('href', viewAllUrl0);
            $('#search-view-all').prop('hidden', false);
            return;
        }

        /* ─── Normal results ─── */
        $('#search-zero-result').prop('hidden', true);
        var gridHtml = '';
        $.each(result.items, function (i, entry) {
            gridHtml += buildProductCard(entry.product, query, entry.matchType);
        });
        $('#search-products-grid').html(gridHtml);
        $('#search-products-section').prop('hidden', false);

        var viewAllUrl = searchUrl + '?' + encodeURIComponent(queryParamName) + '=' + encodeURIComponent(query);
        $('#search-view-all-btn').attr('href', viewAllUrl);
        $('#search-view-all').prop('hidden', false);
    }

    function updateSearchPlaceholder() {
        var $searchInput = getSearchInput();
        var currentTerm;

        if (!$searchInput.length || ($searchInput.is(':focus') && $.trim($searchInput.val()))) {
            return;
        }

        currentTerm = popularSearchTerms.length
            ? popularSearchTerms[placeholderIndex % popularSearchTerms.length]
            : (translations.searchPlaceholderFallback || 'products');

        $searchInput.attr(
            'placeholder',
            (translations.searchPlaceholderPattern || 'Search "%1"').replace('%1', currentTerm)
        );
    }

    function startPlaceholderRotation() {
        updateSearchPlaceholder();

        if (placeholderIntervalId || popularSearchTerms.length <= 1) {
            return;
        }

        placeholderIntervalId = window.setInterval(function () {
            var $searchInput = getSearchInput();

            if (!$searchInput.length || $searchInput.is(':focus') || $.trim($searchInput.val())) {
                return;
            }

            placeholderIndex = (placeholderIndex + 1) % popularSearchTerms.length;
            updateSearchPlaceholder();
        }, 3000);
    }

    function fetchSearchSuggestions() {
        var query = $.trim(getSearchInput().val());

        if (!query.length) {
            hideSearchResults();
            showDefaultState();
            updateSearchPlaceholder();
            return;
        }

        if (suggestionRequest && suggestionRequest.readyState !== 4) {
            suggestionRequest.abort();
        }

        /* ─── Instant client-side results via intent engine ─── */
        renderSearchResults(query);

        /* Fire-and-forget API call (results already shown from local DB) */
        suggestionRequest = $.ajax({
            url: suggestProductsUrl,
            data: { q: query },
            dataType: 'json',
            cache: false
        }).done(function () {
            /* API results ignored — local intent engine handles display */
        }).fail(function () {
            /* Local results already showing, nothing to do */
        });
    }

    function isCustomerLoggedIn(customer) {
        return !!(customer && (customer.fullname || customer.firstname));
    }

    function renderCustomerState(customer) {
        var loggedIn = isCustomerLoggedIn(customer);

        $('#custom-welcome').text((translations.welcome || 'Welcome, %1!').replace('%1', getCustomerDisplayName(customer)));
        $('.auth-menu-item[data-auth-state="logged-in"]').prop('hidden', !loggedIn);
        $('.auth-menu-item[data-auth-state="guest"]').prop('hidden', loggedIn);
    }

    function toggleMenu(show) {
        $('#dior-side-menu').toggleClass('open', show);
        $('#menu-overlay').toggleClass('show', show);
        $('body').toggleClass('csc-no-scroll', show || $('#search-overlay').hasClass('show'));
    }

    function toggleSearch(show) {
        $('#search-bar').toggleClass('show', show);
        $('#search-overlay').toggleClass('show', show);
        $('body').toggleClass('csc-no-scroll', show || $('#menu-overlay').hasClass('show'));

        if (show) {
            window.setTimeout(function () {
                getSearchInput().trigger('focus');
                updateSearchPlaceholder();
                /* Show default state with mock products and suggestions immediately */
                if (!$.trim(getSearchInput().val())) {
                    showDefaultState();
                }
            }, 180);
            return;
        }

        if (suggestionRequest && suggestionRequest.readyState !== 4) {
            suggestionRequest.abort();
        }

        window.clearTimeout(suggestionTimerId);
        getSearchInput().val('');
        hideSearchResults();
        updateSearchPlaceholder();
    }

    $(document).on('click', '#custom-hamburger', function () { toggleMenu(true); });
    $(document).on('click', '#close-btn, #menu-overlay', function () { toggleMenu(false); });
    $(document).on('click', '#custom-search-icon', function () { toggleSearch(true); });
    $(document).on('click focus', '#inline-search-trigger', function () { toggleSearch(true); });
    $(document).on('click', '#search-close, #search-overlay', function () { toggleSearch(false); });

    /* Category pill → fill input + search */
    $(document).on('click', '.search-pill[data-category]', function (e) {
        e.preventDefault();
        $('.search-pill').removeClass('active');
        $(this).addClass('active');
        var pillText = $(this).attr('data-category');
        getSearchInput().val(pillText);
        $('#search-input-clear').addClass('visible');
        fetchSearchSuggestions();
    });

    /* Suggestion pill → toggle active + fill input + search */
    $(document).on('click', '.search-pill[data-suggest]', function (e) {
        e.preventDefault();
        $('.search-pill[data-suggest]').removeClass('active');
        $(this).addClass('active');
        var pillText = $(this).attr('data-suggest');
        getSearchInput().val(pillText);
        $('#search-input-clear').addClass('visible');
        fetchSearchSuggestions();
    });

    mountHeaderBar();
    renderCustomerState(customerData.get('customer')());
    customerData.get('customer').subscribe(renderCustomerState);
    startPlaceholderRotation();

    $(document).on('input propertychange', '#custom-search-input', function () {
        window.clearTimeout(suggestionTimerId);

        var val = $.trim(this.value);
        if (val) {
            $('#search-input-clear').addClass('visible');
        } else {
            $('#search-input-clear').removeClass('visible');
        }

        if (!val) {
            hideSearchResults();
            showDefaultState();
            updateSearchPlaceholder();
            return;
        }

        suggestionTimerId = window.setTimeout(fetchSearchSuggestions, 220);
    });

    $(document).on('click', '#search-input-clear', function () {
        getSearchInput().val('').trigger('focus');
        hideSearchResults();
        showDefaultState();
        updateSearchPlaceholder();
    });

    $(document).on('focus', '#custom-search-input', function () {
        updateSearchPlaceholder();

        if ($.trim(this.value).length) {
            fetchSearchSuggestions();
        }
    });

    $(document).on('keydown', '#custom-search-input', function (event) {
        if (event.key === 'Escape') {
            toggleSearch(false);
        }
    });

    $(document).on('submit', '#search_form', function (event) {
        if (!$.trim(getSearchInput().val())) {
            event.preventDefault();
        }
    });

