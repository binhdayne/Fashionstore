.fs-msg{display:flex;flex-direction:column;gap:3px;max-width:85%}
.fs-msg.bot{align-self:flex-start}
.fs-msg.user{align-self:flex-end}
.fs-msg-sender{font-size:8px;letter-spacing:.2em;text-transform:uppercase;color:#9a9590;padding:0 2px}
.fs-msg.user .fs-msg-sender{text-align:right}
.fs-msg-bubble{padding:10px 14px;font-size:12px;line-height:1.7;letter-spacing:.02em}
.fs-msg.bot .fs-msg-bubble{background:#f0ede8;color:#0a0a0a;border-left:1.5px solid #b8976a}
.fs-msg.user .fs-msg-bubble{background:#0a0a0a;color:#fafaf8}
.fs-typing{display:flex;gap:4px;align-items:center;padding:10px 14px;background:#f0ede8;border-left:1.5px solid #b8976a;width:fit-content}
.fs-typing span{width:4px;height:4px;border-radius:50%;background:#b8976a;animation:fs-dot 1.2s infinite}
.fs-typing span:nth-child(2){animation-delay:.2s}
.fs-typing span:nth-child(3){animation-delay:.4s}
@keyframes fs-dot{0%,100%{opacity:.3;transform:scale(.8)}50%{opacity:1;transform:scale(1)}}
#fs-suggestions{padding:0 16px 10px;display:flex;flex-wrap:wrap;gap:6px;background:#fafaf8}
.fs-chip{font-family:'Montserrat','Helvetica Neue',sans-serif;font-size:9px;letter-spacing:.12em;text-transform:uppercase;padding:5px 10px;border:0.5px solid #c8c3bc;background:transparent;color:#6a6560;cursor:pointer;transition:all .2s}
.fs-chip:hover{border-color:#b8976a;color:#b8976a;background:#faf8f5}
#fs-footer{border-top:0.5px solid #e8e5e0;padding:12px 14px;display:flex;align-items:center;gap:10px;background:#fafaf8}
#fs-input{flex:1;border:none;background:transparent;font-family:'Cormorant Garamond',Georgia,serif;font-size:13px;font-style:italic;letter-spacing:.04em;color:#0a0a0a;outline:none}
#fs-input::placeholder{color:#b8b3ac}
#fs-send{width:32px;height:32px;background:#0a0a0a;border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:background .2s;flex-shrink:0}
