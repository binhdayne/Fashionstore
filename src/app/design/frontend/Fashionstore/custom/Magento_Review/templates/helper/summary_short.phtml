<?php
/**
 * Custom review summary for PDP: stars + average score + review count.
 *
 * @var \Magento\Review\Block\Product\ReviewRenderer $block
 */

$url = $block->getReviewsUrl() . '#reviews';
$urlForm = $block->getReviewsUrl() . '#review-form';
$reviewsCount = (int) $block->getReviewsCount();
$ratingPercent = (float) $block->getRatingSummary();
$averageScore = $reviewsCount > 0 ? round($ratingPercent / 20, 1) : 0.0;
$activeStars = (int) round($averageScore);
?>
<?php if ($block->isReviewEnabled()): ?>
    <div class="product-reviews-summary short fashionstore-reviews-summary<?= $reviewsCount === 0 ? ' empty' : '' ?>">
        <div class="fashionstore-stars" aria-label="<?= $block->escapeHtmlAttr(__('Average rating: %1 out of 5', $averageScore)) ?>">
            <?php for ($i = 1; $i <= 5; $i++): ?>
                <span class="fashionstore-star<?= $i <= $activeStars ? ' is-active' : '' ?>">★</span>
            <?php endfor; ?>
        </div>
        <div class="reviews-actions">
            <?php if ($reviewsCount > 0): ?>
                <a class="action view" href="<?= $block->escapeUrl($url) ?>">
                    <span class="fashionstore-rating-value"><?= $block->escapeHtml(number_format($averageScore, 1)) ?></span>
                    <span class="fashionstore-review-count">(<?= $block->escapeHtml($reviewsCount) ?>)</span>
                </a>
            <?php else: ?>
                <a class="action add" href="<?= $block->escapeUrl($urlForm) ?>">
                    <span class="fashionstore-rating-value">0.0</span>
                    <span class="fashionstore-review-count">(0)</span>
                </a>
            <?php endif; ?>
        </div>
    </div>
<?php endif; ?>
