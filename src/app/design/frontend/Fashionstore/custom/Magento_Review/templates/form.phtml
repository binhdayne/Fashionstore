<?php
/** @var \Magento\Review\Block\Form $block */
$objectManager = \Magento\Framework\App\ObjectManager::getInstance();
$customerSession = $objectManager->get(\Magento\Customer\Model\Session::class);
$customerName = '';
if ($customerSession->isLoggedIn()) {
    $customer = $customerSession->getCustomer();
    $customerName = trim((string) $customer->getName());
    if ($customerName === '') {
        $customerName = trim((string) $customer->getEmail());
    }
}
if ($customerName === '') {
    $customerName = 'Khách hàng';
}
$ratingLabels = [
    'Quality' => 'Chất lượng',
    'Value' => 'Giá trị',
    'Price' => 'Giá cả',
];
$buttonLockManager = $block->getData('button_lock_manager');
$orderItemId = (int) $block->getRequest()->getParam('order_item_id');
