<script>
    (function () {
        'use strict';

        function buildFullGalleryGrid() {
            var galleries = document.querySelectorAll('.catalog-product-view .fotorama-item');

            galleries.forEach(function (gallery) {
                var stage = gallery.querySelector('.fotorama__stage'),
                    grid = gallery.querySelector('.fashionstore-gallery-grid'),
                    navThumbs = Array.from(gallery.querySelectorAll('.fotorama__nav__frame img')),
                    altText,
                    seen = {},
                    uniqueUrls = [],
                    displayUrls = [];

                if (!stage || !navThumbs.length) {
                    return;
                }

                altText = (stage.querySelector('img') || navThumbs[0]).getAttribute('alt') || '';

                if (!grid) {
                    grid = document.createElement('div');
                    grid.className = 'fashionstore-gallery-grid';
                    stage.parentNode.insertBefore(grid, stage.nextSibling);
                }

                navThumbs.forEach(function (thumb) {
                    var src = thumb.currentSrc || thumb.getAttribute('src') || thumb.getAttribute('data-src') || thumb.src || '',
                        parsed,
                        cleanPath,
                        fullUrl;

                    if (!src) {
                        return;
                    }

                    try {
                        parsed = new URL(src, window.location.origin);
                    } catch (error) {
                        return;
                    }

                    cleanPath = parsed.pathname;
                    if (cleanPath.indexOf('/media/catalog/product/') === -1) {
                        return;
                    }

                    cleanPath = cleanPath.replace(/\/cache\/[^/]+\//, '/');

                    fullUrl = window.location.origin + cleanPath;
                    if (!seen[fullUrl]) {
                        seen[fullUrl] = true;
                        uniqueUrls.push(fullUrl);
                    }
                });

                if (!uniqueUrls.length) {
                    return;
                }

                displayUrls = uniqueUrls.slice(0, 4);

                if (!displayUrls.length) {
                    return;
                }

                if (grid.querySelectorAll('.fashionstore-gallery-grid__img').length === displayUrls.length) {
                    var currentUrls = Array.from(grid.querySelectorAll('.fashionstore-gallery-grid__img')).map(function (img) {
                            return img.getAttribute('src') || '';
                        }),
                        normalizedCurrent = currentUrls.map(function (url) {
                            return url.split('?')[0];
                        }),
                        normalizedTarget = displayUrls.map(function (url) {
                            return url.split('?')[0];
                        }),
                        isSameOrder = normalizedCurrent.length === normalizedTarget.length &&
                            normalizedCurrent.every(function (url, index) {
                                return url === normalizedTarget[index];
                            });

                    if (isSameOrder) {
                        return;
                    }
                }

                grid.innerHTML = '';
                displayUrls.forEach(function (url, index) {
                    var cell = document.createElement('div'),
                        img = document.createElement('img');

                    cell.className = 'fashionstore-gallery-grid__cell';
                    img.className = 'fashionstore-gallery-grid__img';
                    img.src = url;
                    img.alt = altText;
                    img.loading = index < 2 ? 'eager' : 'lazy';

                    cell.appendChild(img);
                    grid.appendChild(cell);
                });

                gallery.classList.add('fashionstore-grid-ready');
            });
        }

        function moveReviewSummaryNearPrice() {
            var productMain = document.querySelector('.catalog-product-view .product-info-main'),
                summary,
                infoPrice,
                priceBox;

            if (!productMain) {
                return;
            }

            summary = productMain.querySelector('.fashionstore-reviews-summary');
            infoPrice = productMain.querySelector('.product-info-price');
            priceBox = infoPrice ? infoPrice.querySelector('.price-box') : null;

            if (!summary || !infoPrice || !priceBox) {
                return;
            }

            if (summary.parentElement !== infoPrice) {
                infoPrice.insertBefore(summary, priceBox.nextSibling);
            }
        }

        function closeAllShareModal() {
            document.querySelectorAll('[data-role="share-modal"]').forEach(function (modal) {
                modal.setAttribute('hidden', 'hidden');
                modal.classList.remove('is-open');
            });
            document.querySelectorAll('[data-role="share-toggle"]').forEach(function (toggle) {
                toggle.setAttribute('aria-expanded', 'false');
            });
            document.body.classList.remove('fashionstore-share-open');
        }

        function bindShareModalFallback() {
            var wrap = document.querySelector('[data-role="share-wrap"]'),
                toggle,
                modal,
                dialog,
                closeTriggers;

            if (!wrap || wrap.getAttribute('data-share-fallback-bound') === '1') {
                return;
            }

            toggle = wrap.querySelector('[data-role="share-toggle"]');
            modal = wrap.querySelector('[data-role="share-modal"]');
            dialog = wrap.querySelector('[data-role="share-modal-dialog"]');
            closeTriggers = wrap.querySelectorAll('[data-role="share-close"], [data-role="share-close-btn"]');

            if (!toggle || !modal) {
                return;
            }

            wrap.setAttribute('data-share-fallback-bound', '1');

            toggle.addEventListener('click', function (event) {
                var isOpen = !modal.hasAttribute('hidden') && modal.classList.contains('is-open');

                event.preventDefault();
                closeAllShareModal();

                if (!isOpen) {
                    modal.removeAttribute('hidden');
                    modal.classList.add('is-open');
                    toggle.setAttribute('aria-expanded', 'true');
                    document.body.classList.add('fashionstore-share-open');
                }
            });

            closeTriggers.forEach(function (node) {
                node.addEventListener('click', function (event) {
                    event.preventDefault();
                    closeAllShareModal();
                });
            });

            if (dialog) {
                dialog.addEventListener('click', function (event) {
                    event.stopPropagation();
                });
            }
        }

        if (!document.querySelector('[data-role="share-wrap"][data-inline-share-handler="1"]')) {
            document.addEventListener('click', function (event) {
                var toggle = event.target.closest('[data-role="share-toggle"]'),
                    closeTrigger = event.target.closest('[data-role="share-close"], [data-role="share-close-btn"]'),
                    modalDialog = event.target.closest('[data-role="share-modal-dialog"]'),
                    wrap,
                    modal,
                    isOpen;

                if (toggle) {
                    event.preventDefault();
                    wrap = toggle.closest('[data-role="share-wrap"]');
                    modal = wrap ? wrap.querySelector('[data-role="share-modal"]') : null;
                    if (!modal) {
                        return;
                    }

                    isOpen = !modal.hasAttribute('hidden') && modal.classList.contains('is-open');
                    closeAllShareModal();

                    if (!isOpen) {
                        modal.removeAttribute('hidden');
                        modal.classList.add('is-open');
                        toggle.setAttribute('aria-expanded', 'true');
                        document.body.classList.add('fashionstore-share-open');
                    }
                    return;
                }

                if (closeTrigger) {
                    event.preventDefault();
                    closeAllShareModal();
                    return;
                }

                if (modalDialog) {
                    event.stopPropagation();
                }
            }, true);
        }

        document.addEventListener('keydown', function (event) {
            if (event.key === 'Escape') {
                closeAllShareModal();
            }
        });

        buildFullGalleryGrid();
        moveReviewSummaryNearPrice();
        bindShareModalFallback();
        document.addEventListener('contentUpdated', buildFullGalleryGrid);
        document.addEventListener('contentUpdated', moveReviewSummaryNearPrice);
        document.addEventListener('contentUpdated', bindShareModalFallback);
        window.setTimeout(buildFullGalleryGrid, 150);
        window.setTimeout(buildFullGalleryGrid, 500);
        window.setTimeout(buildFullGalleryGrid, 900);
        window.setTimeout(buildFullGalleryGrid, 1400);
        window.setTimeout(moveReviewSummaryNearPrice, 120);
        window.setTimeout(moveReviewSummaryNearPrice, 420);
        window.setTimeout(bindShareModalFallback, 120);
        window.setTimeout(bindShareModalFallback, 420);
    }());
</script>