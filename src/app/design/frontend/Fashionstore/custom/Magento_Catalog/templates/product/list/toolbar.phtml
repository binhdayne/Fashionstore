        /* Dual-range slider track */
        .fs-slider-track-wrap {
            position: relative !important;
            height: 18px !important;
        }
        .fs-slider-track {
            position: absolute !important;
            left: 8px !important;
            right: 8px !important;
            top: 50% !important;
            height: 3px !important;
            transform: translateY(-50%) !important;
            background: #d8d8d8 !important;
