    <div class="toolbar toolbar-products" data-mage-init='{"productListToolbarForm":<?= /* @noEscape */ $widgetOptions ?>}'>
        <?php if ($block->getIsBottom()): ?>
            <?= $block->getPagerHtml() ?>
            <?= $block->fetchView($block->getTemplateFile('Magento_Catalog::product/list/toolbar/limiter.phtml')) ?>
        <?php else: ?>
            <?php if ($block->isExpanded()): ?>
                <?= $block->fetchView($block->getTemplateFile('Magento_Catalog::product/list/toolbar/viewmode.phtml')) ?>
            <?php endif ?>

            <?= $block->fetchView($block->getTemplateFile('Magento_Catalog::product/list/toolbar/amount.phtml')) ?>

            <?php if ($block->isExpanded()): ?>
                <div class="fashionstore-toolbar-meta">
                    <div class="fashionstore-price-filter-wrap" data-role="fashionstore-price-filter-wrap">
                        <label for="<?= $block->escapeHtmlAttr($priceSelectId) ?>" class="fashionstore-price-filter-label">
                            <?= $block->escapeHtml(__('Khoảng giá')) ?>
                        </label>
                        <select id="<?= $block->escapeHtmlAttr($priceSelectId) ?>"
                                class="fashionstore-price-filter-select"
                                data-role="fashionstore-price-filter-select">
                            <option value=""><?= $block->escapeHtml(__('Tất cả mức giá')) ?></option>
                        </select>
                        <div class="fashionstore-price-custom">
                            <input type="number"
                                   min="0"
                                   step="1000"
                                   class="fashionstore-price-input"
                                   placeholder="<?= $block->escapeHtmlAttr(__('Từ')) ?>"
                                   data-role="fashionstore-price-min">
                            <span class="fashionstore-price-separator">-</span>
                            <input type="number"
                                   min="0"
                                   step="1000"
                                   class="fashionstore-price-input"
                                   placeholder="<?= $block->escapeHtmlAttr(__('Đến')) ?>"
                                   data-role="fashionstore-price-max">
                            <button type="button" class="fashionstore-price-apply" data-role="fashionstore-price-apply">
                                <?= $block->escapeHtml(__('Áp dụng')) ?>
                            </button>
                        </div>
                    </div>

                    <?= $block->fetchView($block->getTemplateFile('Magento_Catalog::product/list/toolbar/sorter.phtml')) ?>
                </div>

                <script>
                    require(['jquery'], function ($) {
                        var $toolbar = $('#<?= $block->escapeJs($priceSelectId) ?>').closest('.toolbar-products'),
                            $wrap = $toolbar.find('[data-role="fashionstore-price-filter-wrap"]'),
                            $select = $toolbar.find('[data-role="fashionstore-price-filter-select"]'),
                            $minInput = $toolbar.find('[data-role="fashionstore-price-min"]'),
                            $maxInput = $toolbar.find('[data-role="fashionstore-price-max"]'),
                            $applyBtn = $toolbar.find('[data-role="fashionstore-price-apply"]'),
                            currentUrl = window.location.href.split('#')[0],
                            $priceFilterItem,
                            $links;

                        function parsePriceValue(raw) {
                            var text = (raw || '').toString().trim();
                            if (!text) {
                                return '';
                            }
                            text = text.replace(/[^0-9]/g, '');
                            return text;
                        }

                        function getPriceFromUrl(url) {
                            var u,
                                value,
                                parts;

                            try {
                                u = new URL(url, window.location.origin);
                                value = u.searchParams.get('price') || '';
                                if (!value) {
                                    return {min: '', max: ''};
                                }
                                parts = value.split('-');
                                return {
                                    min: parsePriceValue(parts[0] || ''),
                                    max: parsePriceValue(parts[1] || '')
                                };
                            } catch (e) {
                                return {min: '', max: ''};
                            }
                        }

                        function applyCustomPrice() {
                            var min = parsePriceValue($minInput.val()),
                                max = parsePriceValue($maxInput.val()),
                                url = new URL(window.location.href, window.location.origin),
                                priceValue;

                            if (!min && !max) {
                                url.searchParams.delete('price');
                                window.location.href = url.toString();
                                return;
                            }

                            if (min && max && Number(min) > Number(max)) {
                                return;
                            }

                            priceValue = (min || '0') + '-' + (max || '');
                            url.searchParams.set('price', priceValue);
                            window.location.href = url.toString();
                        }

                        $priceFilterItem = $('.block.filter .filter-options-item').filter(function () {
                            var title = $(this).find('.filter-options-title').first().text().trim().toLowerCase();
                            return title.indexOf('giá') !== -1 || title.indexOf('gia') !== -1 || title.indexOf('price') !== -1;
                        }).first();

                        if (!$priceFilterItem.length) {
                            $wrap.hide();
                            return;
                        }

                        $links = $priceFilterItem.find('.filter-options-content a');
                        if (!$links.length) {
                            $wrap.hide();
                            return;
                        }

                        $links.each(function () {
                            var $link = $(this),
                                href = $link.attr('href'),
                                label = $link.text().trim();

                            if (!href || !label) {
                                return;
                            }

                            $('<option></option>').val(href).text(label).appendTo($select);
                        });

                        $select.find('option').each(function () {
                            var value = ($(this).val() || '').split('#')[0];
                            if (value && currentUrl.indexOf(value) === 0) {
                                $(this).prop('selected', true);
                            }
                        });

                        (function presetPriceInputsFromCurrentUrl() {
                            var current = getPriceFromUrl(window.location.href);
                            $minInput.val(current.min);
                            $maxInput.val(current.max);
                        })();

                        $select.on('change', function () {
                            var value = $(this).val(),
                                selectedPrice = getPriceFromUrl(value);

                            $minInput.val(selectedPrice.min);
                            $maxInput.val(selectedPrice.max);

                            if (!value) {
                                applyCustomPrice();
                                return;
                            }
                            window.location.href = value;
                        });

                        $applyBtn.on('click', applyCustomPrice);

                        $minInput.add($maxInput).on('keydown', function (event) {
                            if (event.key === 'Enter') {
                                event.preventDefault();
                                applyCustomPrice();
                            }
                        });
                    });
                </script>
            <?php endif ?>
        <?php endif ?>
    </div>
<?php endif ?>
