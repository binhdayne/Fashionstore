			   rel="noopener noreferrer"
			   title="<?= $block->escapeHtmlAttr(__('Mở Instagram để chia sẻ link sản phẩm')) ?>">
				<span><?= $block->escapeHtml(__('Chia sẻ Instagram')) ?></span>
			</a>
		</div>
	</div>
</div>
