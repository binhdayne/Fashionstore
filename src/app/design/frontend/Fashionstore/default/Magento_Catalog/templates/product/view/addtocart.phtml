<?php $_product = $block->getProduct(); ?>
<?php $buttonTitle = __('Thêm vào giỏ hàng'); ?>
<?php $buyNowTitle = __('Mua ngay'); ?>
<?php
$productUrl = $_product ? (string) $_product->getProductUrl() : '';
$facebookShareUrl = 'https://www.facebook.com/sharer/sharer.php?u=' . rawurlencode($productUrl);
$instagramShareUrl = 'https://www.instagram.com/';
$loginUrl = $block->getUrl('customer/account/login');
?>
<?php if ($_product->isSaleable()) :?>
<div class="box-tocart fashionstore-pdp-buybox">
	<div class="fieldset">
		<?php if ($block->shouldRenderQuantity()) :?>
		<div class="field qty">
			<label class="label" for="qty"><span><?= $block->escapeHtml(__('Số lượng')) ?></span></label>
			<div class="control">
				<button type="button"
						class="qty-btn qty-btn-minus"
						data-role="qty-decrease"
						aria-label="<?= $block->escapeHtmlAttr(__('Giảm số lượng')) ?>">-</button>
				<input type="number"
					   name="qty"
					   id="qty"
					   min="1"
					   value="<?= $block->getProductDefaultQty() * 1 ?>"
					   title="<?= $block->escapeHtmlAttr(__('Qty')) ?>"
					   class="input-text qty"
					   data-validate="<?= $block->escapeHtml(json_encode($block->getQuantityValidators())) ?>"
					   />
				<button type="button"
						class="qty-btn qty-btn-plus"
						data-role="qty-increase"
						aria-label="<?= $block->escapeHtmlAttr(__('Tăng số lượng')) ?>">+</button>
			</div>
		</div>
		<?php endif; ?>
		<input type="hidden" name="return_url" value="" data-role="buy-now-return-url">
		<input type="hidden" name="fashionstore_buy_now" value="0" data-role="buy-now-flag">
		<div class="actions fashionstore-product-actions">
			<button type="submit"
					title="<?= $block->escapeHtmlAttr($buttonTitle) ?>"
					class="action primary tocart"
					id="product-addtocart-button" disabled>
				<span><?= $block->escapeHtml($buttonTitle) ?></span>
			</button>
			<button type="button"
					title="<?= $block->escapeHtmlAttr($buyNowTitle) ?>"
					class="action secondary buynow"
					id="product-buynow-button"
					data-role="buy-now"
					disabled>
				<span><?= $block->escapeHtml($buyNowTitle) ?></span>
			</button>
			<?= $block->getChildHtml('', true) ?>
		</div>
		<div class="fashionstore-buy-now-login-required" data-role="buy-now-login-required" hidden>
			<?= $block->escapeHtml(__('Vui lòng')) ?>
			<a href="<?= $block->escapeUrl($loginUrl) ?>" data-role="buy-now-login-link">
				<?= $block->escapeHtml(__('Đăng nhập')) ?>
			</a>
			<?= $block->escapeHtml(__('để sử dụng Mua ngay.')) ?>
		</div>
		<div class="fashionstore-buy-now-size-required" data-role="buy-now-size-required" hidden>
			<?= $block->escapeHtml(__('Vui lòng chọn size trước khi mua ngay.')) ?>
		</div>
		<div class="fashionstore-share-actions" aria-label="<?= $block->escapeHtmlAttr(__('Chia sẻ sản phẩm')) ?>">
			<a class="fashionstore-share-link facebook"
			   href="<?= $block->escapeUrl($facebookShareUrl) ?>"
			   target="_blank"
			   rel="noopener noreferrer">
				<span><?= $block->escapeHtml(__('Chia sẻ Facebook')) ?></span>
			</a>
			<a class="fashionstore-share-link instagram"
