<?php $_product = $block->getProduct(); ?>
<?php $buttonTitle = __('Thêm vào giỏ hàng'); ?>
<?php $buyNowTitle = __('Mua ngay'); ?>
<?php
$productUrl = $_product ? (string) $_product->getProductUrl() : '';
$productName = $_product ? (string) $_product->getName() : '';
$facebookShareUrl = 'https://www.facebook.com/sharer/sharer.php?u=' . rawurlencode($productUrl);
$instagramShareUrl = 'https://www.instagram.com/?url=' . rawurlencode($productUrl);
$xShareUrl = 'https://twitter.com/intent/tweet?url=' . rawurlencode($productUrl) . '&text=' . rawurlencode($productName);
$mediaBaseUrl = rtrim((string) $block->getBaseUrl(), '/') . '/media/';
$facebookIconUrl = $mediaBaseUrl . 'share-icons/facebook.png';
$instagramIconUrl = $mediaBaseUrl . 'share-icons/instagram.png';
$xIconUrl = $mediaBaseUrl . 'share-icons/x.png';
$loginReferer = $productUrl !== '' ? base64_encode($productUrl) : '';
$loginParams = $loginReferer !== '' ? ['referer' => $loginReferer] : [];
$loginUrl = $block->getUrl('customer/account/login', $loginParams);
?>
<?php if ($_product->isSaleable()) :?>
<div class="box-tocart fashionstore-pdp-buybox">
	<div class="fieldset">
