<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
  <head>
    <css src="css/custom.css"/>
    <script src="js/header-enhancements.js"/>
  </head>
  <body>
    <referenceBlock name="fashionstore.contactwidget" remove="true"/>
    <move element="minicart" destination="header" after="-"/>
    <referenceBlock name="header">
      <action method="setTemplate">
        <argument name="template" xsi:type="string">Magento_Theme::html/header.phtml</argument>
      </action>
    </referenceBlock>
    <referenceContainer name="before.body.end">
      <block class="Magento\Framework\View\Element\Template" name="fashionstore.back.to.top">
        <arguments>
          <argument name="template" xsi:type="string">Magento_Theme::html/back_to_top.phtml</argument>
        </arguments>
      </block>
    </referenceContainer>
  </body>
</page>