<script>
require(['jquery'], function($) {
    let newsItems = [];
    let newsIdx = 0;
    let interval = null;

    function showNews() {
        if (!newsItems.length) return;

        $('#news-title')
            .stop(true, true)
            .fadeOut(200, function() {
                $(this)
                    .text(newsItems[newsIdx])
                    .fadeIn(200);
            });

        newsIdx = (newsIdx + 1) % newsItems.length;
    }

    function startSlider() {
        if (interval) return;
        interval = setInterval(showNews, 6000);
    }

    function loadNews() {
        try {
            $.get("https://api.rss2json.com/v1/api.json?rss_url=https://vnexpress.net/rss/kinh-doanh.rss")
                .done(function(data) {
                    if (data && data.items && data.items.length) {
                        newsItems = data.items.map(item => item.title);

                        $('#news-title').text(newsItems[0]);
                        startSlider();
                    }
                })
                .fail(function() {
                    console.log("RSS load fail");
                });
        } catch (e) {
            console.log("Error:", e);
        }
    }

    // ⏱ delay để không block header
    setTimeout(loadNews, 2000);
});
</script>
<script>
require(['jquery'], function($) {

    // 3. Xử lý đóng mở Menu
    $(document).on('click', '#custom-hamburger', function() {
        $('#dior-side-menu').addClass('open');
        $('#menu-overlay').addClass('show');
        $('body').addClass('csc-no-scroll');
    });

    $(document).on('click', '#close-btn, #menu-overlay', function() {
        $('#dior-side-menu').removeClass('open');
        $('#menu-overlay').removeClass('show');
        $('body').removeClass('csc-no-scroll');
    });

    $(document).on('click', '#search-close, #search-overlay', function() {
        $('#search-overlay').removeClass('show');
        $('#search-bar').removeClass('show');
        $('body').removeClass('csc-no-scroll');
    });

    // Placeholder changing for best-selling products
    let bestSellers = ["denim", "áo thun nam", "quần jean nữ", "giày sneaker", "túi xách da"];
    let placeholderIdx = 0;
    let placeholderInterval = null;

    function changePlaceholder() {
        $('#search_overlay').attr('placeholder', 'Tìm "' + bestSellers[placeholderIdx] + '"');
        placeholderIdx = (placeholderIdx + 1) % bestSellers.length;
    }

    function startPlaceholderChange() {
        if (placeholderInterval) clearInterval(placeholderInterval);
        placeholderInterval = setInterval(changePlaceholder, 3000);
        changePlaceholder(); // Initial call
    }

    function stopPlaceholderChange() {
        if (placeholderInterval) {
            clearInterval(placeholderInterval);
            placeholderInterval = null;
        }
    }

    // Start when search is opened
    $(document).on('click', '#custom-search-icon', function() {
        $('#search-overlay').addClass('show');
        $('#search-bar').addClass('show');
        $('body').addClass('csc-no-scroll');
        $('#search_overlay').focus();
        startPlaceholderChange();
    });

    // Stop when closed
    $(document).on('click', '#search-close, #search-overlay', function() {
        $('#search-overlay').removeClass('show');
        $('#search-bar').removeClass('show');
        $('body').removeClass('csc-no-scroll');
        stopPlaceholderChange();
    });

    const suggestUrl = '<?= $block->getUrl('fashionstore_weather/ajax/suggest') ?>';
    const minSearchLength = 1;
    let suggestTimeout = null;

    function renderSuggestions(items) {
        const container = $('#search_autocomplete_overlay');
        if (!items || !items.length) {
            container.hide().empty();
            return;
        }
        const list = $('<ul>').addClass('autocomplete-list');
        items.forEach(item => {
            const title = $('<span>').text(item.title || item.title || item.name || item.value || '');
            const url = item.url || item.product_url || '#';
            const li = $('<li>').append($('<a>').attr('href', url).append(title));
            list.append(li);
        });
        container.empty().append(list).show();
    }

    $('#search_overlay').on('input', function() {
        const q = $.trim($(this).val());
        if (q.length < minSearchLength) {
            renderSuggestions([]);
            return;
        }

        if (suggestTimeout) {
            clearTimeout(suggestTimeout);
        }
        suggestTimeout = setTimeout(function() {
            $.ajax({
                url: suggestUrl,
                type: 'GET',
                dataType: 'json',
                data: { q: q },
                success: function(data) {
                    if (data && data.length) {
                        renderSuggestions(data);
                    } else {
                        // Fallback: try built-in endpoint if module-based endpoint is empty
                        $.ajax({
                            url: '<?= $escaper->escapeUrl($quickSearchUrl) ?>',
                            type: 'GET',
                            dataType: 'json',
                            data: { q: q },
                            success: function(builtinData) {
                                renderSuggestions(builtinData || []);
                            },
                            error: function() {
                                renderSuggestions([]);
                            }
                        });
                    }
                },
                error: function() {
                    renderSuggestions([]);
                }
            });
        }, 250);
    });

    $(document).on('click', function(e) {
        if (!$(e.target).closest('#search-bar').length && !$(e.target).is('#custom-search-icon')) {
            $('#search_autocomplete_overlay').hide();
        }
    });

    $(document).on('keydown', function(e) {
        if (e.keyCode === 27 && $('#search-overlay').hasClass('show')) {
            $('#search-overlay').removeClass('show');
            $('#search-bar').removeClass('show');
            $('body').removeClass('csc-no-scroll');
        }
    });


});
</script>
