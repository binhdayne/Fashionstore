<style>
    /* 1. Ẩn Menu mặc định và các thành phần thừa */
    .navigation, .nav-sections, .nav-toggle, .header.links, .page-header .header.panel .welcome { display: none !important; }
    
    /* 2. Cấu trúc Header Trắng */
    .header.content { 
        display: flex !important; 
        align-items: center; 
        justify-content: space-between; 
        padding: 10px 20px !important; 
        max-width: 100% !important; 
        position: relative !important;
        background: #fff;
        height: 60px;
    }
    
    /* Nút Hamburger - Đưa sang góc trái */
    #custom-hamburger { 
        order: 1; 
        cursor: pointer; 
        z-index: 1002; 
        width: 30px;
        display: flex;
        flex-direction: column;
        gap: 5px;
    }
    #custom-hamburger div { width: 22px; height: 1px; background: #333; }

    /* Logo - Ép nằm chính giữa */
    .logo { 
        position: absolute !important; 
        left: 50% !important; 
        top: 50% !important;
        transform: translate(-50%, -50%) !important; 
        margin: 0 !important; 
        z-index: 1000; 
    }
    .logo img { max-height: 35px; width: auto; }

    /* Side Menu trượt */
    #dior-side-menu {
        position: fixed; top: 0; left: -100%; width: 300px; height: 100vh;
        background: #fff; z-index: 9999; transition: 0.4s ease;
        padding: 80px 40px; box-shadow: 5px 0 15px rgba(0,0,0,0.1);
    }
    #dior-side-menu.open { left: 0 !important; }
    .close-menu { position: absolute; top: 30px; left: 40px; cursor: pointer; font-size: 11px; text-transform: uppercase; color: #999; }
</style>

<div id="custom-hamburger">
    <div></div>
    <div></div>
</div>

<div id="dior-side-menu">
    <div class="close-menu">✕ Close</div>
    <ul style="list-style:none; padding:0; margin-top:20px;">
        <li style="padding:15px 0; border-bottom:1px solid #f2f2f2;"><a href="/ao-nam.html" style="text-decoration:none; color:#333; text-transform:uppercase;">Áo Nam</a></li>
        <li style="padding:15px 0; border-bottom:1px solid #f2f2f2;"><a href="/quan-nam.html" style="text-decoration:none; color:#333; text-transform:uppercase;">Quần Nam</a></li>
        <li style="padding:15px 0; border-bottom:1px solid #f2f2f2;"><a href="/ao-nu.html" style="text-decoration:none; color:#333; text-transform:uppercase;">Áo Nữ</a></li>
    </ul>
</div>

<script>
require(['jquery'], function($) {
    $('#custom-hamburger').on('click', function() { $('#dior-side-menu').addClass('open'); });
    $('.close-menu').on('click', function() { $('#dior-side-menu').removeClass('open'); });
});
</script>
