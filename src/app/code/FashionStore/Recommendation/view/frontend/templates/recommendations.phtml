<?php
/** @var \FashionStore\Recommendation\Block\Recommendations $block */
if (!$block->isEnabled()) {
    return;
}
?>
<style>
.fashionstore-recommendation{margin:32px 0;padding:28px;border:1px solid #e7dccf;background:linear-gradient(135deg,#fffaf4 0%,#f4eee5 100%)}
.fashionstore-recommendation__heading{margin:0 0 14px;text-align:center;font:600 34px/1.1 "Cormorant Garamond",serif;letter-spacing:.06em;text-transform:none;color:#b8976a}
.fashionstore-recommendation__status{display:none}
.fashionstore-recommendation__grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:18px}
.fashionstore-recommendation__card{display:flex;flex-direction:column;gap:10px;padding:14px;background:#fff;border:1px solid rgba(138,113,90,.18);text-decoration:none;transition:transform .2s ease,box-shadow .2s ease, border-color .2s ease}
.fashionstore-recommendation__card:hover{transform:translateY(-3px);border-color:#8a715a;box-shadow:0 14px 28px rgba(46,38,31,.08)}
.fashionstore-recommendation__image{aspect-ratio:3/4;width:100%;object-fit:cover;background:#f3ece3}
.fashionstore-recommendation__name{display:block;font:600 17px/1.35 "Cormorant Garamond",serif;color:#2e261f}
.fashionstore-recommendation__price{display:block;font:600 14px/1.3 "Montserrat",sans-serif;color:#b8976a}
.fashionstore-recommendation__price .price{color:#b8976a !important}
.fashionstore-recommendation__reason{display:none}

@media (max-width: 767px){.fashionstore-recommendation{padding:20px}.fashionstore-recommendation__heading{font-size:24px}}
</style>

<section class="fashionstore-recommendation"
         data-url="<?= $block->escapeUrl($block->getAjaxUrl()) ?>"
         data-user-id="<?= $block->escapeHtmlAttr($block->getCurrentUserIdentifier()) ?>"
         data-product-id="<?= (int) $block->getCurrentProductId() ?>"
         data-category-id="<?= (int) $block->getCurrentCategoryId() ?>"
         data-top-k="<?= (int) $block->getDefaultTopK() ?>"
         data-fallback-items="<?= $block->escapeHtmlAttr($block->getFallbackItemsJson(4)) ?>">
    <h2 class="fashionstore-recommendation__heading">Gợi ý cho bạn</h2>
    <div class="fashionstore-recommendation__grid"></div>
</section>

<script>
require(['jquery'], function ($) {
    function renderCards(grid, items) {
        $.each(items, function (_, item) {
            var card = $('<a>', {
                'class': 'fashionstore-recommendation__card',
                href: item.url || '#'
            });

            $('<img>', {
                'class': 'fashionstore-recommendation__image',
                src: item.image || '',
                alt: item.name || ''
            }).appendTo(card);

            $('<span>', {
                'class': 'fashionstore-recommendation__name',
                text: item.name || ''
            }).appendTo(card);

            $('<span>', {
                'class': 'fashionstore-recommendation__price'
            }).html(item.price_html || '').appendTo(card);

            grid.append(card);
        });
    }

    $('.fashionstore-recommendation').each(function () {
        var root = $(this);
        var grid = root.find('.fashionstore-recommendation__grid');
        var fallbackItems = [];

        try {
            fallbackItems = JSON.parse(root.attr('data-fallback-items') || '[]');
        } catch (e) {
            fallbackItems = [];
        }

        $.getJSON(root.data('url'), {
            user_id: root.data('user-id'),
            product_id: root.data('product-id'),
            category_id: root.data('category-id'),
            top_k: root.data('top-k')
        }).done(function (response) {
            var items = response && response.items ? response.items : [];

            if (!items.length) {
                if (fallbackItems.length) {
                    renderCards(grid, fallbackItems.slice(0, 4));
                }
                return;
            }

            renderCards(grid, items);
        }).fail(function () {
            if (fallbackItems.length) {
                renderCards(grid, fallbackItems.slice(0, 4));
            }
        });
    });
});
</script>