        var $headerBar = $('#header-info-bar');
        var $target = $('.page-header .panel.header');

        if (!$headerBar.length || !$target.length) {
            return;
        }

        if (!$headerBar.parent().is($target)) {
            $target.append($headerBar);
        }

        $headerBar.addClass('is-mounted');
