<script>
require(['jquery', 'slick', 'domReady!'], function ($) {
    var sliderTrack = $('#fs-home-hero-slider').find('[data-role="fs-home-hero-track"]');

    if (!sliderTrack.length || sliderTrack.hasClass('slick-initialized')) {
        return;
    }

    sliderTrack.slick({
        slidesToShow: 1,
        slidesToScroll: 1,
        autoplay: false,
        arrows: true,
        dots: true,
        infinite: false,
        speed: 700,
        swipe: true,
        touchMove: true,
        draggable: true,
        pauseOnHover: true,
        pauseOnFocus: true,
        adaptiveHeight: false,
        initialSlide: 0
    });
});
</script>