        <div class="menu-header"><?= $escaper->escapeHtml(__('Account')) ?></div>
        <a href="<?= $escaper->escapeUrl($block->getUrl('customer/account')) ?>" class="menu-item auth-menu-item" data-auth-state="logged-in" hidden><?= $escaper->escapeHtml(__('My Account')) ?> <span>&gt;</span></a>
        <a href="<?= $escaper->escapeUrl($block->getUrl('customer/account/logout')) ?>" class="menu-item auth-menu-item" data-auth-state="logged-in" hidden><?= $escaper->escapeHtml(__('Log Out')) ?> <span>&gt;</span></a>
        <a href="<?= $escaper->escapeUrl($block->getUrl('customer/account/login')) ?>" class="menu-item auth-menu-item" data-auth-state="guest"><?= $escaper->escapeHtml(__('Log In')) ?> <span>&gt;</span></a>
        <a href="<?= $escaper->escapeUrl($block->getUrl('customer/account/create')) ?>" class="menu-item auth-menu-item" data-auth-state="guest"><?= $escaper->escapeHtml(__('Register')) ?> <span>&gt;</span></a>

        <div class="menu-header"><?= $escaper->escapeHtml(__('Store')) ?></div>
        <a href="/ao-nu.html" class="menu-item"><?= $escaper->escapeHtml(__('Women\'s Fashion')) ?> <span>&gt;</span></a>
        <a href="/ao-nam.html" class="menu-item"><?= $escaper->escapeHtml(__('Men\'s Fashion')) ?> <span>&gt;</span></a>
        <a href="/tui-xach.html" class="menu-item"><?= $escaper->escapeHtml(__('Bags')) ?> <span>&gt;</span></a>
        <a href="/giay.html" class="menu-item"><?= $escaper->escapeHtml(__('Shoes')) ?> <span>&gt;</span></a>
    </div>

    <div class="menu-footer">
        <a href="#" style="font-size:12px; color:#666; text-decoration:none; display:block; margin-bottom:10px;"><?= $escaper->escapeHtml(__('Contact us')) ?></a>
        <div class="menu-switcher">
            <div class="switch-btn active"><?= $escaper->escapeHtml(__('Fashion & Accessories')) ?></div>
            <div class="switch-btn"><?= $escaper->escapeHtml(__('Fragrance & Beauty')) ?></div>
        </div>
    </div>
</div>

<div id="search-overlay"></div>
<div id="search-bar">
    <div class="search-top-bar">
        <form id="search_form" action="<?= $escaper->escapeUrl($action) ?>" method="get">
            <input
                id="custom-search-input"
                type="text"
                name="<?= $escaper->escapeHtmlAttr($queryParam) ?>"
                placeholder="<?= $escaper->escapeHtmlAttr(__('Tìm kiếm sản phẩm...')) ?>"
                autocomplete="off"
                maxlength="<?= $escaper->escapeHtmlAttr($maxQueryLength) ?>">
            <span id="search-input-clear" class="search-input-clear">&times;</span>
            <span class="search-input-icon">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            </span>
        </form>
        <div id="search-close">&times;</div>
    </div>
    <div class="search-results-container">
        <div class="search-results-inner">
            <div id="search-pills-section" class="search-suggestions-section">
                <div class="search-section-title"><?= $escaper->escapeHtml(__('Danh mục')) ?></div>
                <div id="search-category-pills" class="search-suggestion-pills"></div>
            </div>
            <div id="search-products-section" class="search-products-section" hidden>
                <div class="search-section-title"><?= $escaper->escapeHtml(__('Kết quả tìm kiếm')) ?></div>
                <div id="search-products-grid" class="search-products-grid"></div>
            </div>
            <div id="search-zero-result" class="search-zero-result" hidden>
                <div class="search-zero-msg"></div>
                <div class="search-section-title"><?= $escaper->escapeHtml(__('Sản phẩm gợi ý cho bạn')) ?></div>
                <div id="search-zero-grid" class="search-products-grid"></div>
            </div>
            <div id="search-view-all" class="search-view-all-wrap" hidden>
                <a id="search-view-all-btn" class="search-view-all-btn" href="#"><?= $escaper->escapeHtml(__('XEM TẤT CẢ')) ?></a>
            </div>
            <div id="search-loading" class="search-products-section" hidden>
                <div class="search-section-title"><?= $escaper->escapeHtml(__('Kết quả tìm kiếm')) ?></div>
                <div class="search-loading-skeleton">
                    <div class="search-skeleton-card"><div class="search-skeleton-img"></div><div class="search-skeleton-text w-60"></div><div class="search-skeleton-text w-30"></div><div class="search-skeleton-text w-40"></div></div>
                    <div class="search-skeleton-card"><div class="search-skeleton-img"></div><div class="search-skeleton-text w-60"></div><div class="search-skeleton-text w-30"></div><div class="search-skeleton-text w-40"></div></div>
                    <div class="search-skeleton-card"><div class="search-skeleton-img"></div><div class="search-skeleton-text w-60"></div><div class="search-skeleton-text w-30"></div><div class="search-skeleton-text w-40"></div></div>
                    <div class="search-skeleton-card"><div class="search-skeleton-img"></div><div class="search-skeleton-text w-60"></div><div class="search-skeleton-text w-30"></div><div class="search-skeleton-text w-40"></div></div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
require(['jquery', 'Magento_Customer/js/customer-data'], function ($, customerData) {
    var popularSearchTerms = <?= /* @noEscape */ $popularSearchTermsJson ?: '[]' ?>;
    var translations = <?= /* @noEscape */ $translationStringsJson ?: '{}' ?>;
    var suggestProductsUrl = '<?= $escaper->escapeJs($suggestProductsUrl) ?>';
    var weatherUrl = '<?= $escaper->escapeJs($weatherUrl) ?>';
    var newsUrl = '<?= $escaper->escapeJs($newsUrl) ?>';
    var placeholderIndex = 0;
    var placeholderIntervalId = null;
    var suggestionTimerId = null;
    var suggestionRequest = null;

    /* ═══ PRODUCT DATABASE ═══ */
    var PRODUCTS = [
        /* Áo Nam */
        { id: 1,  name: 'Áo Thun Nam Basic Trắng',    sku: 'ao-nam-001',   price: '199.000đ',     category: 'ao-nam',   image: '/media/import_master/ao-nam-001-1.png' },
        { id: 2,  name: 'Áo Polo Nam Xanh',            sku: 'ao-nam-003',   price: '299.000đ',     category: 'ao-nam',   image: '/media/import_master/ao-nam-003-1.png' },
        /* Áo Nữ */
        { id: 3,  name: 'Áo Thun Nữ Trắng',            sku: 'ao-nu-001',    price: '179.000đ',     category: 'ao-nu',    image: '/media/import_master/ao-nu-001-1.png' },
        { id: 4,  name: 'Áo Sơ Mi Nữ Trắng',           sku: 'ao-nu-003',    price: '349.000đ',     category: 'ao-nu',    image: '/media/import_master/ao-nu-003-1.png' },
        /* Quần Nam */
        { id: 5,  name: 'Quần Jeans Nam Xanh',          sku: 'quan-nam-001', price: '499.000đ',     category: 'quan-nam', image: '/media/import_master/quan-nam-001-1.png' },
        { id: 6,  name: 'Quần Short Nam Thể Thao',      sku: 'quan-nam-005', price: '249.000đ',     category: 'quan-nam', image: '/media/import_master/quan-nam-005-1.png' },
        /* Quần Nữ */
        { id: 7,  name: 'Quần Jeans Nữ Skinny',         sku: 'quan-nu-001',  price: '479.000đ',     category: 'quan-nu',  image: '/media/import_master/quan-nu-001-1.png' },
        { id: 8,  name: 'Quần Palazzo Nữ',              sku: 'quan-nu-004',  price: '419.000đ',     category: 'quan-nu',  image: '/media/import_master/quan-nu-004-1.png' },
        /* Váy Đầm */
        { id: 9,  name: 'Đầm Maxi Hoa Nhí',             sku: 'vay-dam-001',  price: '599.000đ',     category: 'vay-dam',  image: '/media/import_master/vay-dam-001-1.png' },
        { id: 10, name: 'Váy Chữ A Kẻ Sọc',             sku: 'vay-dam-003',  price: '499.000đ',     category: 'vay-dam',  image: '/media/import_master/vay-dam-003-1.png' },
        /* Giày Nam */
        { id: 11, name: 'Giày Sneaker Nam Trắng',        sku: 'giay-nam-001', price: '799.000đ',     category: 'giay-nam', image: '/media/import_master/giay-nam-001-1.png' },
        { id: 12, name: 'Giày Oxford Nam',                sku: 'giay-nam-003', price: '1.299.000đ',   category: 'giay-nam', image: '/media/import_master/giay-nam-003-1.png' },
        /* Giày Nữ */
        { id: 13, name: 'Giày Cao Gót Đen',              sku: 'giay-nu-001',  price: '899.000đ',     category: 'giay-nu',  image: '/media/import_master/giay-nu-001-1.png' },
        { id: 14, name: 'Giày Sneaker Nữ Trắng',         sku: 'giay-nu-003',  price: '699.000đ',     category: 'giay-nu',  image: '/media/import_master/giay-nu-003-1.png' },
        /* Túi Xách */
        { id: 15, name: 'Túi Xách Nữ Da Đen',            sku: 'tui-xach-001', price: '1.299.000đ',   category: 'tui-xach', image: '/media/import_master/tui-xach-001-1.png' },
        { id: 16, name: 'Balo Nữ Thời Trang',             sku: 'tui-xach-004', price: '499.000đ',     category: 'tui-xach', image: '/media/import_master/tui-xach-004-1.png' },
        /* Phụ Kiện */
        { id: 17, name: 'Thắt Lưng Nam Da',               sku: 'phu-kien-001', price: '399.000đ',     category: 'phu-kien', image: '/media/import_master/phu-kien-001-1.png' },
        { id: 18, name: 'Kính Mát Nữ',                    sku: 'phu-kien-004', price: '499.000đ',     category: 'phu-kien', image: '/media/import_master/phu-kien-004-1.png' },
        /* Sale */
        { id: 19, name: 'Áo Thun Nam Sale 50%',           sku: 'sale-001',     price: '99.000đ',      category: 'sale',     image: '/media/import_master/sale-001-1.png' },
        { id: 20, name: 'Giày Sneaker Sale',               sku: 'sale-003',     price: '399.000đ',     category: 'sale',     image: '/media/import_master/sale-003-1.png' }
    ];

    var CATEGORY_LABELS = {
        'ao-nam': 'Áo Nam', 'ao-nu': 'Áo Nữ',
        'quan-nam': 'Quần Nam', 'quan-nu': 'Quần Nữ',
        'vay-dam': 'Váy Đầm', 'giay-nam': 'Giày Nam',
        'giay-nu': 'Giày Nữ', 'tui-xach': 'Túi Xách',
        'phu-kien': 'Phụ Kiện', 'sale': 'Sale'
    };

    var intentMap = {
        'tui-xach': ['túi', 'balo', 'clutch', 'ví'],
        'phu-kien': ['phụ kiện', 'thắt lưng', 'mũ', 'kính', 'vòng tay', 'dây chuyền', 'khăn', 'tất', 'vớ'],
        'vay-dam': ['váy', 'đầm'],
        'giay-nam': ['giày nam', 'dép nam', 'sneaker nam', 'boot nam'],
        'giay-nu': ['giày nữ', 'dép nữ', 'cao gót', 'búp bê'],
        'ao-nam': ['áo nam', 'áo thun nam', 'áo polo', 'sơ mi nam', 'hoodie', 'bomber'],
        'quan-nam': ['quần nam', 'jeans nam', 'kaki nam', 'quần short nam'],
        'ao-nu': ['áo nữ', 'áo thun nữ', 'sơ mi nữ', 'croptop', 'blazer'],
        'quan-nu': ['quần nữ', 'jeans nữ', 'culottes', 'palazzo', 'legging'],
        'sale': ['sale', 'giảm giá', 'rẻ']
    };

    function removeAccents(str) {
        return (str || '').toLowerCase()
            .normalize('NFD').replace(/[\u0300-\u036f]/g, '')
            .replace(/đ/g, 'd').replace(/Đ/g, 'D');
    }

    function resolveIntentCategory(nQuery) {
        var cats = Object.keys(intentMap);
        var bestMatch = null;
        var bestLen = 0;
        for (var c = 0; c < cats.length; c++) {
            var keywords = intentMap[cats[c]];
            for (var k = 0; k < keywords.length; k++) {
                var nKw = removeAccents(keywords[k]);
                if (nQuery.indexOf(nKw) !== -1 && nKw.length > bestLen) {
                    bestMatch = cats[c];
                    bestLen = nKw.length;
                }
            }
        }
        return bestMatch;
    }

    function handleSearch(rawQuery) {
        var query = $.trim(rawQuery).replace(/\s+/g, ' ').toLowerCase();
        var nQuery = removeAccents(query);
        if (!nQuery.replace(/\s+/g, '')) {
            return { items: [], title: '', isFallback: false, query: query };
        }

        var nameMatches = [];
        var skuMatches = [];
        var intentMatches = [];
        var intentCategory = resolveIntentCategory(nQuery);

        for (var i = 0; i < PRODUCTS.length; i++) {
            var p = PRODUCTS[i];
            var nName = removeAccents(p.name);
            var nSku = removeAccents(p.sku);
            if (nName.indexOf(nQuery) !== -1) {
                nameMatches.push({ product: p, matchType: 'name' });
            } else if (nSku.indexOf(nQuery) !== -1) {
                skuMatches.push({ product: p, matchType: 'sku' });
            } else if (intentCategory && p.category === intentCategory) {
                intentMatches.push({ product: p, matchType: 'intent' });
            }
        }

        var results = nameMatches.concat(skuMatches).concat(intentMatches);

        if (results.length === 0) {
            var sales = PRODUCTS.filter(function (p) { return p.category === 'sale'; });
            var shuffled = sales.slice();
            for (var si = shuffled.length - 1; si > 0; si--) {
                var sj = Math.floor(Math.random() * (si + 1));
                var tmp = shuffled[si]; shuffled[si] = shuffled[sj]; shuffled[sj] = tmp;
            }
            var fallback = [];
            for (var fi = 0; fi < Math.min(shuffled.length, 4); fi++) {
                fallback.push({ product: shuffled[fi], matchType: 'sale' });
            }
            return { items: fallback, title: 'Sản phẩm gợi ý cho bạn', isFallback: true, query: query };
        }

        if (results.length < 4) {
            results = padResults(results, 4);
        } else {
            results = results.slice(0, 4);
        }

        return { items: results, title: 'Kết quả tìm kiếm', isFallback: false, query: query };
    }

    function padResults(existing, target) {
        if (existing.length >= target) return existing.slice(0, target);
        var cat = existing[0].product.category;
        var usedIds = {};
        for (var i = 0; i < existing.length; i++) usedIds[existing[i].product.id] = true;

        for (var j = 0; j < PRODUCTS.length && existing.length < target; j++) {
            if (PRODUCTS[j].category === cat && !usedIds[PRODUCTS[j].id]) {
                existing.push({ product: PRODUCTS[j], matchType: 'pad' });
                usedIds[PRODUCTS[j].id] = true;
            }
        }

        if (existing.length < target) {
            var sales = PRODUCTS.filter(function (p) { return p.category === 'sale' && !usedIds[p.id]; });
            for (var s = 0; s < sales.length && existing.length < target; s++) {
                existing.push({ product: sales[s], matchType: 'sale' });
            }
        }

        return existing.slice(0, target);
    }

    function getUniqueCategories() {
        var seen = {};
        var cats = [];
        for (var i = 0; i < PRODUCTS.length; i++) {
            var slug = PRODUCTS[i].category;
            if (slug && !seen[slug]) {
                seen[slug] = true;
                cats.push({ slug: slug, label: CATEGORY_LABELS[slug] || slug });
            }
        }
        return cats;
    }

    function getHighlightedText(text, query, matchType) {
        var safe = escapeHtml(text);
        if (!query || matchType !== 'name') return safe;
        var nQuery = removeAccents(query);
        var nText = removeAccents(text);
        var idx = nText.indexOf(nQuery);
        if (idx === -1) return safe;
        var before = escapeHtml(text.substring(0, idx));
        var match = escapeHtml(text.substring(idx, idx + query.length));
        var after = escapeHtml(text.substring(idx + query.length));
        return before + '<strong class="text-black font-extrabold">' + match + '</strong>' + after;
    }

    function getCustomerDisplayName(customer) {
        if (!customer) {
            return translations.guest || 'Guest';
        }

        return customer.fullname || customer.firstname || translations.guest || 'Guest';
    }

    function escapeHtml(value) {
        return $('<div>').text(value || '').html();
    }

    function getSearchInput() {
        return $('#custom-search-input');
    }

    function hideSearchResults() {
        $('#search-products-section').prop('hidden', true);
        $('#search-zero-result').prop('hidden', true);
        $('#search-view-all').prop('hidden', true);
        $('#search-loading').prop('hidden', true);
        $('#search-products-grid').empty();
        $('#search-zero-grid').empty();
        $('#search-input-clear').removeClass('visible');
    }

    function buildProductCard(item, query, matchType) {
        var nameHtml = getHighlightedText(item.name, query, matchType);
        return '<a class="search-product-card" href="/' + escapeHtml(item.sku) + '.html">' +
            '<div class="search-product-img-wrap">' +
            '<img class="search-product-img" src="' + escapeHtml(item.image) + '" alt="' + escapeHtml(item.name) + '" loading="eager" decoding="sync" onerror="this.src=\'https://placehold.co/400x533/f9fafb/a1a1aa?text=No+Image\'">' +
            '</div>' +
            '<div class="search-product-name">' + nameHtml + '</div>' +
            '<div class="search-product-sku">' + escapeHtml(item.sku) + '</div>' +
            '<div class="search-product-price">' + escapeHtml(item.price) + '</div>' +
            '</a>';
    }

    function showDefaultState() {
        $('#search-products-section').prop('hidden', true);
        $('#search-zero-result').prop('hidden', true);
        $('#search-view-all').prop('hidden', true);
        $('#search-loading').prop('hidden', true);

        var cats = getUniqueCategories();
        var pillsHtml = '';
        $.each(cats, function (i, cat) {
            pillsHtml += '<a class="search-pill" href="#" data-category="' + escapeHtml(cat.label) + '">' +
                '<span>' + escapeHtml(cat.label) + '</span></a>';
        });
        $('#search-category-pills').html(pillsHtml);
        $('#search-pills-section').prop('hidden', false);
    }

    function renderSearchResults(query) {
        var result = handleSearch(query);
        var gridHtml = '';
        var searchUrl = $('#search_form').attr('action');
        var queryParamName = '<?= $escaper->escapeJs($queryParam) ?>';

        $('#search-loading').prop('hidden', true);

        if ($.trim(query)) {
            $('#search-input-clear').addClass('visible');
        } else {
            $('#search-input-clear').removeClass('visible');
        }

        if (result.items.length === 0 && !result.isFallback) {
            $('#search-products-section').prop('hidden', true);
            $('#search-zero-result').prop('hidden', true);
            return;
        }

        if (result.isFallback) {
            $('#search-products-section').prop('hidden', true);
            var zeroHtml = '';
            $.each(result.items, function (i, entry) {
                zeroHtml += buildProductCard(entry.product, null, 'sale');
            });
            $('#search-zero-result .search-zero-msg').text(
                'Không tìm thấy sản phẩm phù hợp với "' + query + '"'
            );
            $('#search-zero-grid').html(zeroHtml);
            $('#search-zero-result').prop('hidden', false);

            var viewAllUrl0 = searchUrl + '?' + encodeURIComponent(queryParamName) + '=' + encodeURIComponent(query);
            $('#search-view-all-btn').attr('href', viewAllUrl0);
            $('#search-view-all').prop('hidden', false);
            return;
        }

        $('#search-zero-result').prop('hidden', true);
        $('#search-products-section .search-section-title').text(result.title);
        $.each(result.items, function (i, entry) {
            gridHtml += buildProductCard(entry.product, query, entry.matchType);
        });
        $('#search-products-grid').html(gridHtml);
        $('#search-products-section').prop('hidden', false);

        var viewAllUrl = searchUrl + '?' + encodeURIComponent(queryParamName) + '=' + encodeURIComponent(query);
        $('#search-view-all-btn').attr('href', viewAllUrl);
        $('#search-view-all').prop('hidden', false);
    }

    function updateSearchPlaceholder() {
        var $searchInput = getSearchInput();
        var currentTerm;

        if (!$searchInput.length || ($searchInput.is(':focus') && $.trim($searchInput.val()))) {
            return;
        }

        currentTerm = popularSearchTerms.length
            ? popularSearchTerms[placeholderIndex % popularSearchTerms.length]
            : (translations.searchPlaceholderFallback || 'products');

        $searchInput.attr(
            'placeholder',
            (translations.searchPlaceholderPattern || 'Search "%1"').replace('%1', currentTerm)
        );
    }

    function startPlaceholderRotation() {
        updateSearchPlaceholder();

        if (placeholderIntervalId || popularSearchTerms.length <= 1) {
            return;
        }

        placeholderIntervalId = window.setInterval(function () {
            var $searchInput = getSearchInput();

            if (!$searchInput.length || $searchInput.is(':focus') || $.trim($searchInput.val())) {
                return;
            }

            placeholderIndex = (placeholderIndex + 1) % popularSearchTerms.length;
            updateSearchPlaceholder();
        }, 3000);
    }

    function fetchSearchSuggestions() {
        var query = $.trim(getSearchInput().val());

        if (!query.length) {
            hideSearchResults();
            showDefaultState();
            updateSearchPlaceholder();
            return;
        }

        if (suggestionRequest && suggestionRequest.readyState !== 4) {
            suggestionRequest.abort();
        }

        /* ─── Instant client-side results via intent engine ─── */
        renderSearchResults(query);

        /* Fire-and-forget API call (results already shown from local DB) */
        suggestionRequest = $.ajax({
            url: suggestProductsUrl,
            data: { q: query },
            dataType: 'json',
            cache: false
        }).done(function () {
            /* API results ignored — local intent engine handles display */
        }).fail(function () {
            /* Local results already showing, nothing to do */
        });
    }

    function isCustomerLoggedIn(customer) {
        return !!(customer && (customer.fullname || customer.firstname));
    }

    function renderCustomerState(customer) {
        var loggedIn = isCustomerLoggedIn(customer);

        $('#custom-welcome').text((translations.welcome || 'Welcome, %1!').replace('%1', getCustomerDisplayName(customer)));
        $('.auth-menu-item[data-auth-state="logged-in"]').prop('hidden', !loggedIn);
        $('.auth-menu-item[data-auth-state="guest"]').prop('hidden', loggedIn);
    }

    function toggleMenu(show) {
        $('#dior-side-menu').toggleClass('open', show);
        $('#menu-overlay').toggleClass('show', show);
        $('body').toggleClass('csc-no-scroll', show || $('#search-overlay').hasClass('show'));
    }

    function toggleSearch(show) {
        $('#search-bar').toggleClass('show', show);
        $('#search-overlay').toggleClass('show', show);
        $('body').toggleClass('csc-no-scroll', show || $('#menu-overlay').hasClass('show'));

        if (show) {
            window.setTimeout(function () {
                getSearchInput().trigger('focus');
                updateSearchPlaceholder();
                /* Show default state with mock products and suggestions immediately */
                if (!$.trim(getSearchInput().val())) {
                    showDefaultState();
                }
            }, 180);
            return;
        }

        if (suggestionRequest && suggestionRequest.readyState !== 4) {
            suggestionRequest.abort();
        }

        window.clearTimeout(suggestionTimerId);
        getSearchInput().val('');
        hideSearchResults();
        updateSearchPlaceholder();
    }

    $(document).on('click', '#custom-hamburger', function () { toggleMenu(true); });
    $(document).on('click', '#close-btn, #menu-overlay', function () { toggleMenu(false); });
    $(document).on('click', '#custom-search-icon', function () { toggleSearch(true); });
    $(document).on('click focus', '#inline-search-trigger', function () { toggleSearch(true); });
    $(document).on('click', '#search-close, #search-overlay', function () { toggleSearch(false); });

    /* Clicking a category pill */
    $(document).on('click', '.search-pill[data-category]', function (e) {
        e.preventDefault();
        $('.search-pill').removeClass('active');
        $(this).addClass('active');
        var pillText = $(this).attr('data-category');
        getSearchInput().val(pillText);
        $('#search-input-clear').addClass('visible');
        fetchSearchSuggestions();
    });

    renderCustomerState(customerData.get('customer')());
    customerData.get('customer').subscribe(renderCustomerState);
    startPlaceholderRotation();

    $(document).on('input propertychange', '#custom-search-input', function () {
        window.clearTimeout(suggestionTimerId);

        var val = $.trim(this.value);
        if (val) {
            $('#search-input-clear').addClass('visible');
        } else {
            $('#search-input-clear').removeClass('visible');
        }

        if (!val) {
            hideSearchResults();
            showDefaultState();
            updateSearchPlaceholder();
            return;
        }

        suggestionTimerId = window.setTimeout(fetchSearchSuggestions, 220);
    });

    $(document).on('click', '#search-input-clear', function () {
        getSearchInput().val('').trigger('focus');
        hideSearchResults();
        showDefaultState();
        updateSearchPlaceholder();
    });

    $(document).on('focus', '#custom-search-input', function () {
        updateSearchPlaceholder();

        if ($.trim(this.value).length) {
            fetchSearchSuggestions();
        }
    });

    $(document).on('keydown', '#custom-search-input', function (event) {
        if (event.key === 'Escape') {
            toggleSearch(false);
        }
    });

    $(document).on('submit', '#search_form', function (event) {
        if (!$.trim(getSearchInput().val())) {
            event.preventDefault();
        }
    });

    $.getJSON(weatherUrl)
        .done(function (data) {
            if (data && typeof data.temp !== 'undefined' && data.temp !== null) {
                $('#w-temp').text(data.temp + ' C');
            }

            if (data && data.icon) {
                $('#w-icon').attr('src', data.icon).prop('hidden', false);
                return;
            }

            $('#w-icon').attr('src', '').prop('hidden', true);
        })
        .fail(function () {
        $('#w-temp').text('-- C');
        $('#w-icon').attr('src', '').prop('hidden', true);
    });

    $.getJSON(newsUrl)
        .done(function (response) {
            if (response && response.title && response.link) {
                $('#news-title').text(response.title).attr('href', response.link);
            }
        })
        .fail(function () {
            $('#news-title').text(translations.newsLoadFailed || 'Could not load news');
        });
});
</script>
