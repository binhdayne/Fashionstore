<?php
/** @var \FashionStore\CustomHeader\Block\Header $block */
$objectManager = \Magento\Framework\App\ObjectManager::getInstance();
$helper = $objectManager->get(\Magento\Search\Helper\Data::class);
$escaper = $objectManager->get(\Magento\Framework\Escaper::class);
$action = $helper->getResultUrl();
$queryParam = $helper->getQueryParamName();
$guestDisplayName = (string) __('Guest');
$popularSearchTerms = $block->getPopularSearchTerms();
$popularSearchTermsJson = json_encode(
    array_values($popularSearchTerms),
    JSON_UNESCAPED_UNICODE | JSON_HEX_TAG | JSON_HEX_APOS | JSON_HEX_AMP | JSON_HEX_QUOT
);
$suggestProductsUrl = $block->getSuggestProductsUrl();
$weatherUrl = $block->getWeatherUrl();
$newsUrl = $block->getNewsUrl();
$maxQueryLength = $block->getMaxQueryLength();
$translationStringsJson = json_encode(
    [
        'guest' => (string) __('Guest'),
        'welcome' => (string) __('Welcome, %1!'),
        'searchPlaceholderFallback' => (string) __('products'),
        'searchPlaceholderPattern' => (string) __('Search "%1"'),
        'newsLoadFailed' => (string) __('Could not load news'),
    ],
    JSON_UNESCAPED_UNICODE | JSON_HEX_TAG | JSON_HEX_APOS | JSON_HEX_AMP | JSON_HEX_QUOT
);
?>

