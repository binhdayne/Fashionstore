        { id: 96,  name: 'Túi Xách Sale',                   sku: 'sale-005', price: '499.000đ',     category: 'sale', image: '/src/var/import/images/sale-005-1.png' },
        { id: 97,  name: 'Áo Khoác Sale 30%',               sku: 'sale-006', price: '349.000đ',     category: 'sale', image: '/src/var/import/images/sale-006-1.png' },
        { id: 98,  name: 'Phụ Kiện Sale',                    sku: 'sale-007', price: '149.000đ',     category: 'sale', image: '/src/var/import/images/sale-007-1.png' },
        { id: 99,  name: 'Quần Nam Sale',                    sku: 'sale-008', price: '199.000đ',     category: 'sale', image: '/src/var/import/images/sale-008-1.png' },
        { id: 100, name: 'Giày Nữ Sale 50%',                sku: 'sale-009', price: '349.000đ',     category: 'sale', image: '/src/var/import/images/sale-009-1.png' },
        { id: 101, name: 'Áo Nữ Sale Cuối Mùa',             sku: 'sale-010', price: '89.000đ',      category: 'sale', image: '/src/var/import/images/sale-010-1.png' }
    ];

    /* Category slug → Display name mapping for pills/UI */
    var CATEGORY_LABELS = {
        'ao-nam': 'Áo Nam', 'ao-nu': 'Áo Nữ',
        'quan-nam': 'Quần Nam', 'quan-nu': 'Quần Nữ',
        'vay-dam': 'Váy Đầm', 'giay-nam': 'Giày Nam',
        'giay-nu': 'Giày Nữ', 'tui-xach': 'Túi Xách',
        'phu-kien': 'Phụ Kiện', 'sale': 'Sale'
    };

    /* ═══════════════════════════════════════════════════════════════════
     *  SEARCH ENGINE — Intent-based search with Strict Magic 4 Rule
     * ═══════════════════════════════════════════════════════════════════ */

    /* Remove Vietnamese diacritics (Lowercase + Bỏ dấu) */
    function removeAccents(str) {
        return (str || '').toLowerCase()
            .normalize('NFD').replace(/[\u0300-\u036f]/g, '')
            .replace(/đ/g, 'd').replace(/Đ/g, 'D');
    }

    /* Sanitize query: trim, collapse whitespace, lowercase, strip special chars */
    function sanitizeQuery(raw) {
        var trimmed = $.trim(raw).replace(/\s+/g, ' ').toLowerCase();
        return trimmed.replace(/[^a-zA-ZÀ-ỹà-ỹĐđ0-9\s\-]/g, '');
    }

    /* Intent Map: category → keyword arrays */
    var intentMap = {
        'tui-xach': ['túi', 'balo', 'clutch', 'ví'],
        'phu-kien': ['phụ kiện', 'thắt lưng', 'mũ', 'kính', 'vòng tay', 'dây chuyền', 'khăn', 'tất', 'vớ'],
        'vay-dam': ['váy', 'đầm'],
        'giay-nam': ['giày nam', 'dép nam', 'sneaker nam', 'boot nam', 'oxford', 'loafer', 'sandal nam', 'moccasin'],
        'giay-nu': ['giày nữ', 'dép nữ', 'sneaker nữ', 'cao gót', 'búp bê', 'boot nữ', 'wedge', 'mule', 'dép lê'],
        'ao-nam': ['áo nam', 'áo thun nam', 'áo polo', 'sơ mi nam', 'áo khoác nam', 'hoodie', 'bomber', 'áo len nam', 'tank top'],
        'quan-nam': ['quần nam', 'jeans nam', 'kaki nam', 'quần short nam', 'quần tây nam', 'jogger nam', 'quần lửng nam'],
        'ao-nu': ['áo nữ', 'áo thun nữ', 'sơ mi nữ', 'croptop', 'áo kiểu', 'áo len nữ', 'áo khoác nữ', 'blazer'],
        'quan-nu': ['quần nữ', 'jeans nữ', 'culottes', 'palazzo', 'quần short nữ', 'legging', 'quần tây nữ', 'jogger nữ'],
        'sale': ['sale', 'giảm giá', 'rẻ']
    };

    /* Resolve intent: find best matching category from intentMap keywords */
    function resolveIntentCategory(query, nQuery) {
        var cats = Object.keys(intentMap);
        var bestMatch = null;
        var bestLen = 0;
        for (var c = 0; c < cats.length; c++) {
            var keywords = intentMap[cats[c]];
            for (var k = 0; k < keywords.length; k++) {
                var nKw = removeAccents(keywords[k]);
                if (nQuery.indexOf(nKw) !== -1 && nKw.length > bestLen) {
                    bestMatch = cats[c];
                    bestLen = nKw.length;
                }
            }
        }
        return bestMatch;
    }

    /* ══════════════════════════════════════════════════════════════════
     *  handleSearch: Tokenization & Relevance Scoring Engine
     *  +10 = full-phrase match in name
     *  +2  = per-token word match in name
     *  +5  = SKU substring match
     *  +2  = Intent map bonus (category match)
     * ══════════════════════════════════════════════════════════════════ */
    function handleSearch(rawQuery) {
        var query = sanitizeQuery(rawQuery);
        var nQuery = removeAccents(query);

        /* Empty / garbage → no results */
        if (!nQuery || !nQuery.replace(/\s+/g, '')) {
            return { items: [], title: '', zeroResult: true, query: query };
        }

        /* Tokenize query into individual words */
        var tokens = nQuery.split(/\s+/).filter(function (w) { return w.length > 0; });
        var intentCategory = resolveIntentCategory(query, nQuery);
        var scored = [];

        for (var i = 0; i < PRODUCTS.length; i++) {
            var p = PRODUCTS[i];
            var score = 0;
            var mType = 'none';
            var nName = removeAccents(p.name);
            var nameWords = nName.split(/\s+/);

            /* +10: Full-phrase exact substring match in name */
            if (nName.indexOf(nQuery) !== -1) {
                score += 10;
                mType = 'name';
            }

            /* +2 per token: count each token that appears as independent word in name */
            var tokenHits = 0;
            for (var ti = 0; ti < tokens.length; ti++) {
                for (var ni = 0; ni < nameWords.length; ni++) {
                    if (nameWords[ni] === tokens[ti]) {
                        tokenHits++;
                        break;
                    }
                }
            }
            if (tokenHits > 0) {
                score += tokenHits * 2;
                if (mType === 'none') mType = 'name';
            }

            /* +5: SKU substring match */
            var nSku = removeAccents(p.sku);
            if (nSku.indexOf(nQuery) !== -1) {
                score += 5;
                if (mType === 'none') mType = 'sku';
            }

            /* +2: Intent map category match */
            if (intentCategory && p.category === intentCategory) {
                score += 2;
                if (mType === 'none') mType = 'intent';
            }

            /* Product must have matched AT LEAST 1 token to be included */
            if (score > 0 && (tokenHits > 0 || nSku.indexOf(nQuery) !== -1 || (intentCategory && p.category === intentCategory))) {
                scored.push({ product: p, score: score, matchType: mType });
            }
        }

        /* Sort by score descending, then by id ascending for determinism */
        scored.sort(function (a, b) {
            if (b.score !== a.score) return b.score - a.score;
            return a.product.id - b.product.id;
        });

        /* Zero-result: return empty with flag */
        if (scored.length === 0) {
            return { items: [], title: '', zeroResult: true, query: query };
        }

        /* Take top 4 */
        var top4 = [];
        for (var t = 0; t < Math.min(scored.length, 4); t++) {
            top4.push({ product: scored[t].product, matchType: scored[t].matchType });
        }

        if (top4.length < 4) {
            top4 = padResultsTagged(top4, 4);
        }

        return { items: top4, title: 'Kết quả tìm kiếm', zeroResult: false, query: query };
    }

    /* Get N random sale products */
    function getSaleProducts(n) {
        var sales = PRODUCTS.filter(function (p) { return p.category === 'sale'; });
        for (var i = sales.length - 1; i > 0; i--) {
            var j = Math.floor(Math.random() * (i + 1));
            var tmp = sales[i]; sales[i] = sales[j]; sales[j] = tmp;
        }
        return sales.slice(0, n);
    }

    /* Pad results to target count: same-category → phu-kien fallback (tagged version) */
    function padResultsTagged(existing, target) {
        if (existing.length >= target) return existing;

        var cat = existing[0].product.category;
        var usedIds = {};
        for (var i = 0; i < existing.length; i++) usedIds[existing[i].product.id] = true;

        /* Same category first */
        var sameCat = PRODUCTS.filter(function (p) { return p.category === cat && !usedIds[p.id]; });
        for (var sc = 0; sc < sameCat.length && existing.length < target; sc++) {
            existing.push({ product: sameCat[sc], matchType: 'pad' });
            usedIds[sameCat[sc].id] = true;
        }

        /* Still short? Fill with random phu-kien */
        if (existing.length < target) {
            var pk = PRODUCTS.filter(function (p) { return p.category === 'phu-kien' && !usedIds[p.id]; });
            for (var s = pk.length - 1; s > 0; s--) {
                var r = Math.floor(Math.random() * (s + 1));
                var tmp = pk[s]; pk[s] = pk[r]; pk[r] = tmp;
            }
            for (var pi = 0; pi < pk.length && existing.length < target; pi++) {
                existing.push({ product: pk[pi], matchType: 'pad' });
            }
        }

        return existing.slice(0, target);
    }

    /* ═══════════════════════════════════════════════════════════════════
     *  DYNAMIC CATEGORIES — auto-extracted with display labels
     * ═══════════════════════════════════════════════════════════════════ */
    function getUniqueCategories() {
        var seen = {};
        var cats = [];
        for (var i = 0; i < PRODUCTS.length; i++) {
            var slug = PRODUCTS[i].category;
            if (slug && !seen[slug]) {
                seen[slug] = true;
                cats.push(CATEGORY_LABELS[slug] || slug);
            }
        }
        return cats;
    }

    /* ═══════════════════════════════════════════════════════════════════
     *  HIGHLIGHT ENGINE — Smart substring highlighting (Anti-Blur)
     *  CHỈ in đậm khi query thực sự tồn tại trong tên sản phẩm.
     *  Nếu sản phẩm tìm ra nhờ Intent hoặc SKU → KHÔNG in đậm.
     * ═══════════════════════════════════════════════════════════════════ */
    function getHighlightedText(text, query, matchType) {
        var safe = escapeHtml(text);
        if (!query) return safe;

        /* Intent / SKU / sale match → NO highlighting, display normally */
        if (matchType !== 'name') {
            return safe;
        }

        /* Word-boundary highlighting: tokenize query into words,
         * then only bold COMPLETE words in product name that match.
         * NEVER bold partial matches inside another word. */
        var queryWords = removeAccents(query).split(/\s+/).filter(function (w) { return w.length > 0; });
        if (!queryWords.length) return safe;

        /* Split text into words + whitespace tokens */
        var tokens = text.split(/(\s+)/);
        var result = '';

        for (var i = 0; i < tokens.length; i++) {
            var token = tokens[i];
            /* Preserve whitespace as-is */
            if (/^\s+$/.test(token)) {
                result += token;
                continue;
            }
            var nToken = removeAccents(token);
            var isMatch = false;
            for (var j = 0; j < queryWords.length; j++) {
                if (nToken === queryWords[j]) {
                    isMatch = true;
                    break;
                }
            }
            if (isMatch) {
                result += '<strong class="highlight">' + escapeHtml(token) + '</strong>';
            } else {
                result += escapeHtml(token);
            }
        }

        return result;
    }

    function getCustomerDisplayName(customer) {
        if (!customer) {
            return translations.guest || 'Guest';
        }

        return customer.fullname || customer.firstname || translations.guest || 'Guest';
    }

    function escapeHtml(value) {
        return $('<div>').text(value || '').html();
    }

    function getSearchInput() {
        return $('#custom-search-input');
    }

    function hideSearchResults() {
        $('#search-filled-state').prop('hidden', true);
        $('#search-suggestions-section').prop('hidden', true);
        $('#search-products-section').prop('hidden', true);
        $('#search-zero-result').prop('hidden', true);
        $('#search-view-all').prop('hidden', true);
        $('#search-loading').prop('hidden', true);
        $('#search-suggestion-pills').empty();
        $('#search-products-grid').empty();
        $('#search-zero-grid').empty();
        $('#search-input-clear').removeClass('visible');
    }

    function showLoading() {
        $('#search-empty-state-content').prop('hidden', true);
        $('#search-products-section').prop('hidden', true);
        $('#search-loading').prop('hidden', false);
    }

    function hideLoading() {
        $('#search-loading').prop('hidden', true);
    }

    /* ═══════════════════════════════════════════════════════════════════
     *  AUTO-SUGGEST: Generate expanded keyword suggestions
     *  Scans all product names for words that co-occur with the query
     * ═══════════════════════════════════════════════════════════════════ */
    function generateAutoSuggest(query) {
        var nq = removeAccents($.trim(query));
        if (!nq) return [];

        /* Collect product names that contain ANY query token */
        var tokens = nq.split(/\s+/).filter(function (w) { return w.length > 0; });
        var phrases = {};
        var seen = {};

        for (var i = 0; i < PRODUCTS.length; i++) {
            var nName = removeAccents(PRODUCTS[i].name);
            var nameWords = nName.split(/\s+/);
            var hit = false;
            for (var ti = 0; ti < tokens.length; ti++) {
                for (var ni = 0; ni < nameWords.length; ni++) {
                    if (nameWords[ni] === tokens[ti]) { hit = true; break; }
                }
                if (hit) break;
            }
            if (hit && !seen[nName]) {
                seen[nName] = true;
                /* Create 2-3 word expanded phrases from this product name */
                var words = PRODUCTS[i].name.split(/\s+/);
                for (var wi = 0; wi < words.length - 1 && Object.keys(phrases).length < 8; wi++) {
                    var phrase2 = words[wi] + ' ' + words[wi + 1];
                    var nPhrase2 = removeAccents(phrase2);
                    /* Phrase must contain at least one query token */
                    var relevant = false;
                    for (var qi = 0; qi < tokens.length; qi++) {
                        if (nPhrase2.indexOf(tokens[qi]) !== -1) { relevant = true; break; }
                    }
                    if (relevant && !phrases[nPhrase2]) {
                        phrases[nPhrase2] = phrase2;
                    }
                }
            }
        }

        var results = [];
        var keys = Object.keys(phrases);
        for (var k = 0; k < keys.length && results.length < 6; k++) {
            results.push(phrases[keys[k]]);
        }
        return results;
    }

    /* ═══════════════════════════════════════════════════════════════════
     *  TRENDING KEYWORDS & RECENTLY VIEWED (simulated)
     * ═══════════════════════════════════════════════════════════════════ */
    var trendingKeywords = ['Áo thun', 'Quần Shorts', 'Áo Polo', 'Áo khoác', 'Phụ kiện'];

    /* Simulate recently viewed: pick 4 random products (localStorage mock) */
    function getRecentlyViewed() {
        var pool = PRODUCTS.slice();
        for (var i = pool.length - 1; i > 0; i--) {
            var j = Math.floor(Math.random() * (i + 1));
            var tmp = pool[i]; pool[i] = pool[j]; pool[j] = tmp;
        }
        return pool.slice(0, 4);
    }
    var recentlyViewed = getRecentlyViewed();

    /* Build a product card HTML string */
    function buildProductCard(item, query, matchType) {
        var nameHtml = (query && matchType === 'name')
            ? getHighlightedText(item.name, query, matchType)
            : escapeHtml(item.name);

        return '<a class="search-product-card no-underline" href="/' + escapeHtml(item.sku) + '.html">' +
            '<div class="search-product-img-wrap">' +
            '<img class="search-product-img" src="' + escapeHtml(item.image) + '" alt="' + escapeHtml(item.name) + '" loading="eager" decoding="sync" onerror="this.src=\'https://placehold.co/400x533/f9fafb/a1a1aa?text=No+Image\'">' +
            '</div>' +
            '<div class="search-product-name no-underline">' + nameHtml + '</div>' +
            '<div class="search-product-sku no-underline">' + escapeHtml(item.sku) + '</div>' +
            '<div class="search-product-price no-underline">' + escapeHtml(item.price) + '</div>' +
            '</a>';
    }

    /* ═══════════════════════════════════════════════════════════════════
     *  showDefaultState: EMPTY STATE — Trending Keywords + Recently Viewed
     * ═══════════════════════════════════════════════════════════════════ */
    function showDefaultState() {
        /* Hide filled state, show empty state */
        $('#search-filled-state').prop('hidden', true);
        $('#search-loading').prop('hidden', true);
        $('#search-empty-state-content').prop('hidden', false);

        /* Trending keyword pills */
        var trendingHtml = '';
        $.each(trendingKeywords, function (i, kw) {
            trendingHtml += '<a class="search-pill no-underline" href="#" data-trending="' + escapeHtml(kw) + '">' +
                '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="width:14px;height:14px"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>' +
                '<span>' + escapeHtml(kw) + '</span></a>';
        });
        $('#search-trending-pills').html(trendingHtml);

        /* Recently viewed grid */
        var recentHtml = '';
        $.each(recentlyViewed, function (i, item) {
            recentHtml += buildProductCard(item, null, null);
        });
        $('#search-recent-grid').html(recentHtml);
    }

    /* ═══════════════════════════════════════════════════════════════════
     *  renderSearchResults: FILLED STATE — Auto-suggest + Search Results
     * ═══════════════════════════════════════════════════════════════════ */
    function renderSearchResults(query) {
        var $pills = $('#search-suggestion-pills');
        var $grid = $('#search-products-grid');
        var pillsHtml = '';
        var gridHtml = '';
        var searchUrl = $('#search_form').attr('action');
        var queryParamName = '<?= $escaper->escapeJs($queryParam) ?>';

        hideLoading();

        /* Switch to filled state */
        $('#search-empty-state-content').prop('hidden', true);
        $('#search-filled-state').prop('hidden', false);

        /* Clear input indicator */
        if ($.trim(query)) {
            $('#search-input-clear').addClass('visible');
        } else {
            $('#search-input-clear').removeClass('visible');
        }

        /* ─── Auto-suggest pills ─── */
        var suggestItems = generateAutoSuggest(query);
        $.each(suggestItems, function (i, pill) {
            pillsHtml += '<a class="search-pill no-underline" href="#" data-suggest="' + escapeHtml(pill) + '">' +
                '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="width:14px;height:14px"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>' +
                '<span>' + escapeHtml(pill) + '</span></a>';
        });
        $pills.html(pillsHtml);
        $('#search-suggestions-section').prop('hidden', !pillsHtml);

        /* ─── Tokenization & Scoring Engine ─── */
        var result = handleSearch(query);

        /* ─── ZERO-RESULT: Sad Path ─── */
        if (result.zeroResult) {
            $('#search-products-section').prop('hidden', true);
            var zeroHtml = '';
            var featured = getSaleProducts(4);
            $.each(featured, function (i, item) {
                zeroHtml += buildProductCard(item, null, 'sale');
            });
            $('#search-zero-result .search-zero-msg').text(
                'Không tìm thấy sản phẩm phù hợp với từ khóa: "' + query + '"'
            );
            $('#search-zero-grid').html(zeroHtml);
            $('#search-zero-result').prop('hidden', false);

            /* View all button */
            var viewAllUrl0 = searchUrl + '?' + encodeURIComponent(queryParamName) + '=' + encodeURIComponent(query);
            $('#search-view-all-btn').attr('href', viewAllUrl0);
            $('#search-view-all').prop('hidden', false);
            return;
        }

        /* ─── Normal results ─── */
        $('#search-zero-result').prop('hidden', true);
        var displayItems = result.items;

        /* Update section title */
        $('#search-products-section .search-section-title').text(result.title);

        $.each(displayItems, function (i, entry) {
            var item = entry.product;
            var itemMatchType = entry.matchType;
            if (!item || !item.name) return;
            gridHtml += buildProductCard(item, query, itemMatchType);
        });

        $grid.html(gridHtml);
        $('#search-products-section').prop('hidden', !gridHtml);

        /* View all button */
        var viewAllUrl = searchUrl + '?' + encodeURIComponent(queryParamName) + '=' + encodeURIComponent(query);
        $('#search-view-all-btn').attr('href', viewAllUrl);
        $('#search-view-all').prop('hidden', false);
    }

    function updateSearchPlaceholder() {
        var $searchInput = getSearchInput();
        var currentTerm;

        if (!$searchInput.length || ($searchInput.is(':focus') && $.trim($searchInput.val()))) {
            return;
        }

        currentTerm = popularSearchTerms.length
            ? popularSearchTerms[placeholderIndex % popularSearchTerms.length]
            : (translations.searchPlaceholderFallback || 'products');

        $searchInput.attr(
            'placeholder',
            (translations.searchPlaceholderPattern || 'Search "%1"').replace('%1', currentTerm)
        );
    }

    function startPlaceholderRotation() {
        updateSearchPlaceholder();

        if (placeholderIntervalId || popularSearchTerms.length <= 1) {
            return;
        }

        placeholderIntervalId = window.setInterval(function () {
            var $searchInput = getSearchInput();

            if (!$searchInput.length || $searchInput.is(':focus') || $.trim($searchInput.val())) {
                return;
            }

            placeholderIndex = (placeholderIndex + 1) % popularSearchTerms.length;
            updateSearchPlaceholder();
        }, 3000);
    }

    function fetchSearchSuggestions() {
        var query = $.trim(getSearchInput().val());

        if (!query.length) {
            hideSearchResults();
            showDefaultState();
            updateSearchPlaceholder();
            return;
        }

        if (suggestionRequest && suggestionRequest.readyState !== 4) {
            suggestionRequest.abort();
        }

        /* ─── Instant client-side results via intent engine ─── */
        renderSearchResults(query);

        /* Fire-and-forget API call (results already shown from local DB) */
        suggestionRequest = $.ajax({
            url: suggestProductsUrl,
            data: { q: query },
            dataType: 'json',
            cache: false
        }).done(function () {
            /* API results ignored — local intent engine handles display */
        }).fail(function () {
            /* Local results already showing, nothing to do */
        });
    }

    function isCustomerLoggedIn(customer) {
        return !!(customer && (customer.fullname || customer.firstname));
    }

    function renderCustomerState(customer) {
        var loggedIn = isCustomerLoggedIn(customer);

        $('#custom-welcome').text((translations.welcome || 'Welcome, %1!').replace('%1', getCustomerDisplayName(customer)));
        $('.auth-menu-item[data-auth-state="logged-in"]').prop('hidden', !loggedIn);
        $('.auth-menu-item[data-auth-state="guest"]').prop('hidden', loggedIn);
    }

    function toggleMenu(show) {
        $('#dior-side-menu').toggleClass('open', show);
        $('#menu-overlay').toggleClass('show', show);
        $('body').toggleClass('csc-no-scroll', show || $('#search-overlay').hasClass('show'));
    }

    function toggleSearch(show) {
        $('#search-bar').toggleClass('show', show);
        $('#search-overlay').toggleClass('show', show);
        $('body').toggleClass('csc-no-scroll', show || $('#menu-overlay').hasClass('show'));

        if (show) {
            window.setTimeout(function () {
                getSearchInput().trigger('focus');
                updateSearchPlaceholder();
                /* Show default state with mock products and suggestions immediately */
                if (!$.trim(getSearchInput().val())) {
                    showDefaultState();
                }
            }, 180);
            return;
        }

        if (suggestionRequest && suggestionRequest.readyState !== 4) {
            suggestionRequest.abort();
        }

        window.clearTimeout(suggestionTimerId);
        getSearchInput().val('');
        hideSearchResults();
        updateSearchPlaceholder();
    }

    $(document).on('click', '#custom-hamburger', function () { toggleMenu(true); });
    $(document).on('click', '#close-btn, #menu-overlay', function () { toggleMenu(false); });
    $(document).on('click', '#custom-search-icon', function () { toggleSearch(true); });
    $(document).on('click focus', '#inline-search-trigger', function () { toggleSearch(true); });
    $(document).on('click', '#search-close, #search-overlay', function () { toggleSearch(false); });

    /* Clicking a trending pill → fill input + search */
    $(document).on('click', '.search-pill[data-trending]', function (e) {
        e.preventDefault();
        var pillText = $(this).attr('data-trending');
        getSearchInput().val(pillText);
        $('#search-input-clear').addClass('visible');
        fetchSearchSuggestions();
    });

    /* Clicking a suggestion pill → toggle active + fill input + search */
    $(document).on('click', '.search-pill[data-suggest]', function (e) {
        e.preventDefault();
        /* Toggle active state visually */
        $(this).toggleClass('active');
        var pillText = $(this).attr('data-suggest');
        getSearchInput().val(pillText);
        $('#search-input-clear').addClass('visible');
        fetchSearchSuggestions();
    });

    /* Legacy: pills without data attributes */
    $(document).on('click', '.search-pill:not([data-trending]):not([data-suggest])', function (e) {
        e.preventDefault();
        var pillText = $(this).find('span').text();
        getSearchInput().val(pillText);
        $('#search-input-clear').addClass('visible');
        fetchSearchSuggestions();
    });

    renderCustomerState(customerData.get('customer')());
    customerData.get('customer').subscribe(renderCustomerState);
    startPlaceholderRotation();

    $(document).on('input propertychange', '#custom-search-input', function () {
        window.clearTimeout(suggestionTimerId);

        var val = $.trim(this.value);
        if (val) {
            $('#search-input-clear').addClass('visible');
        } else {
            $('#search-input-clear').removeClass('visible');
        }

        if (!val) {
            hideSearchResults();
            showDefaultState();
            updateSearchPlaceholder();
            return;
        }

        suggestionTimerId = window.setTimeout(fetchSearchSuggestions, 220);
    });

    $(document).on('click', '#search-input-clear', function () {
        getSearchInput().val('').trigger('focus');
        hideSearchResults();
        showDefaultState();
        updateSearchPlaceholder();
    });

    $(document).on('focus', '#custom-search-input', function () {
        updateSearchPlaceholder();

        if ($.trim(this.value).length) {
            fetchSearchSuggestions();
        }
    });

    $(document).on('keydown', '#custom-search-input', function (event) {
        if (event.key === 'Escape') {
            toggleSearch(false);
        }
    });

    $(document).on('submit', '#search_form', function (event) {
        if (!$.trim(getSearchInput().val())) {
            event.preventDefault();
        }
    });

    $.getJSON(weatherUrl)
        .done(function (data) {
            if (data && typeof data.temp !== 'undefined' && data.temp !== null) {
                $('#w-temp').text(data.temp + ' C');
            }

            if (data && data.icon) {
                $('#w-icon').attr('src', data.icon).prop('hidden', false);
                return;
            }

            $('#w-icon').attr('src', '').prop('hidden', true);
        })
        .fail(function () {
        $('#w-temp').text('-- C');
        $('#w-icon').attr('src', '').prop('hidden', true);
    });

    $.getJSON(newsUrl)
        .done(function (response) {
            if (response && response.title && response.link) {
                $('#news-title').text(response.title).attr('href', response.link);
            }
        })
        .fail(function () {
            $('#news-title').text(translations.newsLoadFailed || 'Could not load news');
        });
});
</script>
