    #search-bar {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100vh;
        background: #fff;
        z-index: 10001;
        font-family: 'Be Vietnam Pro', 'Montserrat', sans-serif;
        display: flex;
        flex-direction: column;
        opacity: 0;
        visibility: hidden;
        transition: opacity 0.3s ease, visibility 0.3s ease;
    }

    #search-bar.show {
        opacity: 1;
        visibility: visible;
    }

    /* Search top bar */
    .search-top-bar {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 12px;
        padding: 18px 24px;
        border-bottom: 1px solid #eee;
        flex-shrink: 0;
    }

    #search_form {
        position: relative;
        flex: 1;
        max-width: 600px;
    }

    #search_form input {
        width: 100%;
        border: 1px solid #d1d5db;
        border-radius: 999px;
        padding: 12px 80px 12px 44px;
        font-size: 16px;
        outline: none;
        font-family: 'Be Vietnam Pro', 'Montserrat', sans-serif;
        font-weight: 400;
        color: #111;
        background: #fff;
        transition: border-color 0.2s ease;
    }

    #search_form input:focus {
        border-color: #9ca3af;
    }

    #search_form input::placeholder {
        color: #9ca3af;
        font-weight: 300;
    }

    .search-input-icon {
        position: absolute;
        left: 16px;
        top: 50%;
        transform: translateY(-50%);
        pointer-events: none;
        color: #9ca3af;
        display: flex;
        align-items: center;
    }

    .search-input-icon svg {
        width: 18px;
        height: 18px;
    }

    .search-input-clear {
        position: absolute;
        right: 14px;
        top: 50%;
        transform: translateY(-50%);
        cursor: pointer;
        color: #9ca3af;
        font-size: 18px;
        display: none;
        align-items: center;
        justify-content: center;
        width: 28px;
        height: 28px;
        border-radius: 50%;
        background: #f3f4f6;
        transition: background 0.15s;
    }

    .search-input-clear:hover {
        background: #e5e7eb;
    }

    .search-input-clear.visible {
        display: flex;
    }

    #search-close {
        font-size: 28px;
        color: #6b7280;
        cursor: pointer;
        line-height: 1;
        padding: 4px;
        transition: color 0.15s;
        flex-shrink: 0;
    }

    #search-close:hover {
        color: #111;
    }

    /* Search results container */
    .search-results-container {
        flex: 1;
        overflow-y: auto;
        padding: 0;
    }

    .search-results-inner {
        max-width: 1100px;
        margin: 0 auto;
        padding: 28px 32px 40px;
    }

    /* Suggestion pills section */
    .search-suggestions-section {
        margin-bottom: 32px;
    }

    .search-section-title {
        font-size: 14px;
        font-weight: 700;
        color: #111;
        margin-bottom: 14px;
        letter-spacing: 0.04em;
        text-transform: uppercase;
    }

    .search-suggestion-pills {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
    }

    /* Framer Motion-like fade-in + slide-down for the whole content */
    @keyframes searchFadeSlideIn {
        from {
            opacity: 0;
            transform: translateY(-20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    #search-bar.show .search-results-inner {
        animation: searchFadeSlideIn 0.3s cubic-bezier(0.4, 0, 0.2, 1) forwards;
    }

    /* Staggered card animation */
    @keyframes cardFadeIn {
        from {
            opacity: 0;
            transform: translateY(16px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .search-product-card,
    .search-product-card *,
    .no-underline {
        text-decoration: none !important;
    }

    .search-product-card {
        text-decoration: none;
        color: inherit;
        display: flex;
        flex-direction: column;
        transition: transform 0.2s ease;
        opacity: 0;
        animation: cardFadeIn 0.35s cubic-bezier(0.4, 0, 0.2, 1) forwards;
    }

    .search-product-card:nth-child(1) { animation-delay: 0.05s; }
    .search-product-card:nth-child(2) { animation-delay: 0.1s; }
    .search-product-card:nth-child(3) { animation-delay: 0.15s; }
    .search-product-card:nth-child(4) { animation-delay: 0.2s; }

    /* Pills staggered animation */
    @keyframes pillFadeIn {
        from {
            opacity: 0;
            transform: scale(0.92);
        }
        to {
            opacity: 1;
            transform: scale(1);
        }
    }

    .search-pill {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 16px;
        border: 1px solid #e5e7eb;
        border-radius: 999px;
        background: #f9fafb;
        color: #374151;
        font-size: 14px;
        font-weight: 400;
        text-decoration: none;
        cursor: pointer;
        transition: background 0.15s, border-color 0.15s;
        font-family: 'Be Vietnam Pro', 'Montserrat', sans-serif;
        white-space: nowrap;
        opacity: 0;
        animation: pillFadeIn 0.25s ease forwards;
    }

    .search-pill:nth-child(1) { animation-delay: 0.02s; }
    .search-pill:nth-child(2) { animation-delay: 0.06s; }
    .search-pill:nth-child(3) { animation-delay: 0.1s; }
    .search-pill:nth-child(4) { animation-delay: 0.14s; }
    .search-pill:nth-child(5) { animation-delay: 0.18s; }

    .search-pill:hover {
        background: #e5e7eb;
        border-color: #d1d5db;
        color: #111;
    }

    .search-pill svg {
        width: 14px;
        height: 14px;
        color: #9ca3af;
        flex-shrink: 0;
    }

    /* Product results grid */
    .search-products-section {
        margin-bottom: 32px;
    }

    .search-products-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
    }

    .search-product-card:hover {
        transform: translateY(-2px);
    }

    .search-product-img-wrap {
        aspect-ratio: 3 / 4;
        width: 100%;
        overflow: hidden;
        border-radius: 12px;
        margin-bottom: 10px;
        background: #f9fafb;
        position: relative;
    }

    .search-product-img {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center top;
        transition: transform 0.5s ease;
    }

    .search-product-card:hover .search-product-img {
        transform: scale(1.05);
    }

    .search-product-name {
        font-size: 14px;
        font-weight: 400;
        color: #111;
        margin-bottom: 2px;
        line-height: 1.4;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .search-product-name .highlight {
        font-weight: 800;
        color: #000;
    }

    /* Zero-result state */
    .search-zero-result {
        text-align: center;
    }

    .search-zero-msg {
        padding: 24px 0 20px;
        font-size: 15px;
        color: #6b7280;
        font-weight: 400;
    }

    .search-zero-result .search-section-title {
        text-align: left;
    }

    .search-zero-result .search-products-grid {
        text-align: left;
    }

    /* Active pill (toggle black) */
    .search-pill.active {
        background: #111 !important;
        color: #fff !important;
        border-color: #111 !important;
    }

    .search-pill.active svg {
        color: #fff;
    }

    .search-product-sku {
        font-size: 10px;
        color: #9ca3af;
        margin-bottom: 6px;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .search-product-price {
        font-size: 14px;
        font-weight: 700;
        color: #000;
    }

    /* Loading skeleton */
    @keyframes shimmer {
        0% { background-position: -200% 0; }
        100% { background-position: 200% 0; }
    }

    .search-loading-skeleton {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
    }

    .search-skeleton-card {
        display: flex;
        flex-direction: column;
    }

    .search-skeleton-img {
        width: 100%;
        aspect-ratio: 3 / 4;
        border-radius: 12px;
        background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
        background-size: 200% 100%;
        animation: shimmer 1.5s infinite;
        margin-bottom: 10px;
    }

    .search-skeleton-text {
        height: 14px;
        border-radius: 6px;
        background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
        background-size: 200% 100%;
        animation: shimmer 1.5s infinite;
        margin-bottom: 6px;
    }

    .search-skeleton-text.w-60 { width: 60%; }
    .search-skeleton-text.w-40 { width: 40%; }
    .search-skeleton-text.w-30 { width: 30%; }

    /* View all button */
    .search-view-all-wrap {
        text-align: center;
        padding-top: 8px;
    }

    .search-view-all-btn {
        display: inline-block;
        padding: 14px 48px;
        background: #000;
        color: #fff;
        font-size: 13px;
        font-weight: 600;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        border-radius: 999px;
        text-decoration: none;
        border: none;
        cursor: pointer;
        font-family: 'Be Vietnam Pro', 'Montserrat', sans-serif;
        transition: background 0.2s, transform 0.15s;
    }

    .search-view-all-btn:hover {
        background: #333;
        color: #fff;
        transform: translateY(-1px);
    }

    /* Empty / initial state */
    .search-empty-state {
        text-align: center;
        padding: 60px 20px;
        color: #9ca3af;
        font-size: 15px;
    }

    /* Hide old autocomplete */
    .custom-search-autocomplete {
        display: none !important;
    }

    body.csc-no-scroll {
        overflow: hidden;
    }

    @media (max-width: 768px) {
        .search-products-grid {
            grid-template-columns: repeat(2, 1fr);
            gap: 14px;
        }

        .search-results-inner {
            padding: 20px 16px 32px;
        }

        .search-top-bar {
            padding: 14px 16px;
        }

        .search-view-all-btn {
            padding: 12px 36px;
        }
    }

    @media (max-width: 900px) {
        #header-info-bar {
            gap: 12px;
        }

        #news-section,
        #custom-welcome {
            display: none;
        }

        .logo-text,
        .logo-text:visited,
        .logo-text:hover,
        .logo-text:focus {
            font-size: 18px;
            letter-spacing: 0.2em;
        }
    }

    #dior-side-menu.fs-luxe-menu {
        background: radial-gradient(circle at 20% -8%, rgba(250, 218, 148, 0.48), transparent 38%), linear-gradient(180deg, #fff8ec 0%, #ffffff 45%, #f3eadb 100%) !important;
        box-shadow: 22px 0 54px rgba(30, 20, 10, 0.3) !important;
    }

    #dior-side-menu.fs-luxe-menu .menu-content {
        padding: 16px 18px 20px !important;
    }

    #dior-side-menu.fs-luxe-menu .menu-content .menu-header {
        margin: 18px 0 9px !important;
        padding: 10px 12px 8px !important;
        border: 0 !important;
        background: transparent !important;
        color: #8b6422 !important;
        font-size: 12px !important;
        letter-spacing: 0.14em !important;
    }

    #dior-side-menu.fs-luxe-menu .menu-item {
        position: relative !important;
        min-height: 58px !important;
        margin: 9px 0 !important;
        padding: 17px 18px 17px 24px !important;
        border: 1px solid rgba(139, 100, 34, 0.18) !important;
        border-radius: 16px !important;
        background: rgba(255, 255, 255, 0.82) !important;
        color: #20150b !important;
        font-size: 16.5px !important;
        font-weight: 600 !important;
        box-shadow: 0 10px 24px rgba(82, 54, 18, 0.08) !important;
    }

    #dior-side-menu.fs-luxe-menu .menu-item span {
        display: inline-flex !important;
        align-items: center !important;
        justify-content: center !important;
        width: 28px !important;
        height: 28px !important;
        border-radius: 50% !important;
        background: #f3dfb3 !important;
        color: #7b5417 !important;
        font-size: 14px !important;
        font-weight: 700 !important;
    }

    #dior-side-menu.fs-luxe-menu #close-btn {
        background: linear-gradient(135deg, #fff6e5, #efd39b) !important;
        border-bottom: 1px solid rgba(139, 100, 34, 0.2) !important;
        color: #1c140c !important;
    }

    #dior-side-menu.fs-luxe-menu .menu-footer {
        background: linear-gradient(135deg, #17110b 0%, #3a2915 100%) !important;
        color: #f8dfad !important;
    }
</style>

