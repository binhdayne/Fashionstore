    .menu-item {
        position: relative;
        display: flex;
        justify-content: space-between;
        align-items: center;
        min-height: 58px;
        margin: 8px 0;
        padding: 17px 18px 17px 22px;
        border: 1px solid rgba(138, 106, 47, 0.12);
        border-radius: 14px;
        color: #21170d;
        background: rgba(255, 255, 255, 0.74);
        text-decoration: none;
        font-size: 16.5px;
        font-weight: 600;
        line-height: 1.35;
        letter-spacing: 0.01em;
        box-shadow: 0 8px 20px rgba(71, 48, 18, 0.05);
        transition: color 0.18s ease, background-color 0.18s ease, border-color 0.18s ease, box-shadow 0.18s ease, transform 0.18s ease;
    }

    .menu-item::before {
        content: "";
        position: absolute;
        left: 10px;
        top: 50%;
        width: 4px;
        height: 22px;
        border-radius: 999px;
        background: linear-gradient(180deg, #d3a64d, #7f5f2a);
        opacity: 0;
        transform: translateY(-50%) scaleY(0.5);
        transition: opacity 0.18s ease, transform 0.18s ease;
    }

    .menu-item span {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 26px;
        height: 26px;
        border-radius: 50%;
        background: rgba(138, 106, 47, 0.09);
        color: #8a6a2f;
        font-size: 15px;
        font-weight: 700;
        margin-left: 16px;
        transition: color 0.18s ease, background-color 0.18s ease, transform 0.18s ease;
    }

    .menu-item:hover,
    .menu-item:focus {
        background: #fff7e8;
        border-color: rgba(138, 106, 47, 0.34);
        box-shadow: 0 14px 28px rgba(103, 70, 24, 0.12);
        color: #8a6a2f;
        text-decoration: none;
        outline: none;
        transform: translateX(4px);
    }

    .menu-item:hover::before,
    .menu-item:focus::before {
        opacity: 1;
        transform: translateY(-50%) scaleY(1);
    }

    .menu-item:hover span,
    .menu-item:focus span {
        background: #8a6a2f;
        color: #fff;
        transform: translateX(3px);
    }

    .auth-menu-item[hidden] {
