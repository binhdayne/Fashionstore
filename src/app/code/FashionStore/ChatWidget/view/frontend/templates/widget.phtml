<script>
(function(){
  var RAG_URL='<?= $ragUrl ?>';
  var isOpen=false;
  var win=document.getElementById('fs-chat-window');
  var msgs=document.getElementById('fs-messages');
  var inp=document.getElementById('fs-input');
  var sugg=document.getElementById('fs-suggestions');
  function toggle(){isOpen=!isOpen;win.classList.toggle('open',isOpen);if(isOpen)inp.focus();}
  document.getElementById('fs-bubble').addEventListener('click',toggle);
  document.getElementById('fs-close-btn').addEventListener('click',toggle);
  document.querySelectorAll('.fs-chip').forEach(function(c){c.addEventListener('click',function(){inp.value=c.getAttribute('data-q');send();});});
  inp.addEventListener('keydown',function(e){if(e.key==='Enter')send();});
  document.getElementById('fs-send').addEventListener('click',send);
  function esc(s){return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');}
  function addMsg(r,t){var d=document.createElement('div');d.className='fs-msg '+r;d.innerHTML='<div class="fs-msg-sender">'+(r==='bot'?'Maison':'Ban')+'</div><div class="fs-msg-bubble">'+esc(t)+'</div>';msgs.appendChild(d);msgs.scrollTop=msgs.scrollHeight;}
  function showTyping(){var d=document.createElement('div');d.className='fs-msg bot';d.id='fs-typing';d.innerHTML='<div class="fs-msg-sender">Maison</div><div class="fs-typing"><span></span><span></span><span></span></div>';msgs.appendChild(d);msgs.scrollTop=msgs.scrollHeight;}
  function rmTyping(){var t=document.getElementById('fs-typing');if(t)t.remove();}
  function send(){var t=inp.value.trim();if(!t)return;inp.value='';sugg.style.display='none';addMsg('user',t);showTyping();fetch(RAG_URL+'/chat',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({question:t,use_pdf_context:true,use_mysql_context:true})}).then(function(r){return r.json();}).then(function(d){rmTyping();addMsg('bot',d.answer||'Xin loi, toi chua the tra loi.');}).catch(function(){rmTyping();addMsg('bot','Ket noi that bai. Vui long thu lai.');});}
}());
</script>