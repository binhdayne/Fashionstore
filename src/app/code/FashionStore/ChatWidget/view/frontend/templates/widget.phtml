  </svg>
</button>
<script>
(function(){
  var RAG_URL='<?= $ragUrl ?>';
  var isOpen=false;
  var win=document.getElementById('fs-chat-window');
  var msgs=document.getElementById('fs-messages');
  var inp=document.getElementById('fs-input');
  var sugg=document.getElementById('fs-suggestions');
  function toggle(){isOpen=!isOpen;win.classList.toggle('open',isOpen);if(isOpen)inp.focus();}
  document.getElementById('fs-bubble').addEventListener('click',toggle);
  document.getElementById('fs-close-btn').addEventListener('click',toggle);
  // Hover logic for quick contacts (JS-driven since parent has pointer-events:none)
  var group=document.querySelector('.chat-widget-group');
  var launcher=document.querySelector('.fs-chat-launcher');
  var quickContact=document.querySelector('.fs-quick-contact');
  var hoverTimer=null;
  function showContacts(){if(hoverTimer){clearTimeout(hoverTimer);hoverTimer=null;}group.classList.add('fs-contacts-visible');}
  function hideContacts(){hoverTimer=setTimeout(function(){group.classList.remove('fs-contacts-visible');},200);}
  if(launcher){launcher.addEventListener('mouseenter',showContacts);launcher.addEventListener('mouseleave',hideContacts);}
  if(quickContact){quickContact.addEventListener('mouseenter',showContacts);quickContact.addEventListener('mouseleave',hideContacts);}
  var backToTopNodes = document.querySelectorAll('#back-to-top');
  if (backToTopNodes.length > 1) {
    backToTopNodes.forEach(function (node, idx) {
      if (idx > 0) {
        node.removeAttribute('id');
      }
    });
  }

  document.addEventListener('click', function(e) {
    if (e.target && (e.target.id === 'back-to-top' || e.target.closest('#back-to-top'))) {
      window.scrollTo({ top: 0, left: 0, behavior: 'smooth' });
      window.setTimeout(function () {
        if (window.pageYOffset > 0) {
          window.scrollTo(0, 0);
        }
      }, 250);
    }
  });

  function updateBackToTop() {
    var btn = document.getElementById('back-to-top');
    if (btn) {
      btn.style.display = (window.pageYOffset > 300) ? 'flex' : 'none';
    }
  }

  window.addEventListener('scroll', updateBackToTop, { passive: true });
  document.addEventListener('scroll', updateBackToTop, true);

  var backToTopBtn = document.getElementById('back-to-top');
  if (backToTopBtn) {
    backToTopBtn.addEventListener('click', function (event) {
      event.preventDefault();
      window.scrollTo({ top: 0, left: 0, behavior: 'smooth' });
      window.setTimeout(function () {
        if (window.pageYOffset > 0) {
          window.scrollTo(0, 0);
        }
      }, 250);
    });

    updateBackToTop();

    window.setInterval(updateBackToTop, 300);
  }
  document.querySelectorAll('.fs-chip').forEach(function(c){c.addEventListener('click',function(){inp.value=c.getAttribute('data-q');send();});});
  inp.addEventListener('keydown',function(e){if(e.key==='Enter')send();});
  document.getElementById('fs-send').addEventListener('click',send);
  function esc(s){return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');}
  function addMsg(r,t){var d=document.createElement('div');d.className='fs-msg '+r;d.innerHTML='<div class="fs-msg-sender">'+(r==='bot'?'Trợ lý':'Bạn')+'</div><div class="fs-msg-bubble">'+esc(t)+'</div>';msgs.appendChild(d);msgs.scrollTop=msgs.scrollHeight;}
  function showTyping(){var d=document.createElement('div');d.className='fs-msg bot';d.id='fs-typing';d.innerHTML='<div class="fs-msg-sender">Trợ lý</div><div class="fs-typing"><span></span><span></span><span></span></div>';msgs.appendChild(d);msgs.scrollTop=msgs.scrollHeight;}
  function rmTyping(){var t=document.getElementById('fs-typing');if(t)t.remove();}
  function send(){var t=inp.value.trim();if(!t)return;inp.value='';sugg.style.display='none';addMsg('user',t);showTyping();fetch(RAG_URL+'/chat',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({question:t,use_pdf_context:true,use_mysql_context:true})}).then(function(r){return r.json();}).then(function(d){rmTyping();addMsg('bot',d.answer||'Xin loi, toi chua the tra loi.');}).catch(function(){rmTyping();addMsg('bot','Ket noi that bai. Vui long thu lai.');});}
}());
</script>
