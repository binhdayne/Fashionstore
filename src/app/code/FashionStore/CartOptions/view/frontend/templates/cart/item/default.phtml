<script>
if (!window.fashionstoreCartQtyButtonsInitialized) {
    window.fashionstoreCartQtyButtonsInitialized = true;
    document.addEventListener('click', function (event) {
        var button = event.target.closest('[data-qty-action]');
        var input;
        var currentValue;
        var nextValue;

        if (!button) {
            return;
        }

        input = document.querySelector(button.getAttribute('data-target'));
        if (!input) {
            return;
        }

        currentValue = parseInt(input.value || '1', 10);
        if (isNaN(currentValue) || currentValue < 1) {
            currentValue = 1;
        }

        nextValue = button.getAttribute('data-qty-action') === 'increment'
            ? currentValue + 1
            : Math.max(1, currentValue - 1);

        input.value = String(nextValue);
        input.dispatchEvent(new Event('change', { bubbles: true }));
        input.dispatchEvent(new Event('input', { bubbles: true }));
    });
}
</script>
