<?php
/**
 * @var $block \Magento\Checkout\Block\Cart\Item\Renderer
 */

$_item = $block->getItem();
$product = $_item->getProduct();
$helper = $this->helper(Magento\Msrp\Helper\Data::class);
$canApplyMsrp = $helper->isShowBeforeOrderConfirm($product) && $helper->isMinimalPriceLessMsrp($product);
$qtyValue = (float) $block->getQty();
?>
<tbody class="cart item">
    <tr class="item-info">
        <td data-th="<?= $block->escapeHtml(__('Item')) ?>" class="col item">
            <label class="fashionstore-cart-item-selector" for="fashionstore-cart-select-<?= $block->escapeHtmlAttr((string) $_item->getId()) ?>">
                <input id="fashionstore-cart-select-<?= $block->escapeHtmlAttr((string) $_item->getId()) ?>"
                       class="fashionstore-cart-item-selector__input"
                       type="checkbox"
                       value="<?= $block->escapeHtmlAttr((string) $_item->getId()) ?>"
                       data-role="fashionstore-cart-select"
                       data-item-id="<?= $block->escapeHtmlAttr((string) $_item->getId()) ?>"
                       checked>
                <span class="fashionstore-cart-item-selector__control" aria-hidden="true"></span>
                <span class="fashionstore-cart-item-selector__label"><?= $block->escapeHtml(__('Chon san pham nay de thanh toan')) ?></span>
            </label>
            <?php if ($block->hasProductUrl()): ?>
                <a href="<?= $block->escapeUrl($block->getProductUrl()) ?>"
                   title="<?= $block->escapeHtml($block->getProductName()) ?>"
                   tabindex="-1"
                   class="product-item-photo">
            <?php else: ?>
                <span class="product-item-photo">
            <?php endif; ?>
            <?= $block->getImage($block->getProductForThumbnail(), 'cart_page_product_thumbnail')->toHtml() ?>
            <?php if ($block->hasProductUrl()): ?>
                </a>
            <?php else: ?>
                </span>
            <?php endif; ?>
            <div class="product-item-details">
                <strong class="product-item-name">
                    <?php if ($block->hasProductUrl()): ?>
                        <a href="<?= $block->escapeUrl($block->getProductUrl()) ?>"><?= $block->escapeHtml($block->getProductName()) ?></a>
                    <?php else: ?>
                        <?= $block->escapeHtml($block->getProductName()) ?>
                    <?php endif; ?>
                </strong>
                <?php if ($_options = $block->getOptionList()): ?>
                    <dl class="item-options">
                        <?php foreach ($_options as $_option): ?>
                            <?php $_formatedOptionValue = $block->getFormatedOptionValue($_option) ?>
                            <dt><?= $block->escapeHtml($_option['label']) ?></dt>
                            <dd>
                                <?php if (isset($_formatedOptionValue['full_view'])): ?>
                                    <?= $block->escapeHtml($_formatedOptionValue['full_view'], ['span', 'a']) ?>
                                <?php else: ?>
                                    <?= $block->escapeHtml($_formatedOptionValue['value'], ['span', 'a']) ?>
                                <?php endif; ?>
                            </dd>
                        <?php endforeach; ?>
                    </dl>
                <?php endif; ?>
                <?php if ($messages = $block->getMessages()): ?>
                    <?php foreach ($messages as $message): ?>
                        <div class="cart item message <?= $block->escapeHtmlAttr($message['type']) ?>">
                            <div><?= $block->escapeHtml($message['text']) ?></div>
                        </div>
                    <?php endforeach; ?>
                <?php endif; ?>
                <?php $addInfoBlock = $block->getProductAdditionalInformationBlock(); ?>
                <?php if ($addInfoBlock): ?>
                    <?= $addInfoBlock->setItem($_item)->toHtml() ?>
                <?php endif; ?>
            </div>
        </td>

        <?php if ($canApplyMsrp): ?>
            <td class="col msrp" data-th="<?= $block->escapeHtml(__('Price')) ?>">
                <span class="pricing msrp">
                    <span class="msrp notice"><?= $block->escapeHtml(__('See price before order confirmation.')) ?></span>
                </span>
            </td>
        <?php else: ?>
            <td class="col price" data-th="<?= $block->escapeHtml(__('Price')) ?>">
                <?= $block->getUnitPriceHtml($_item) ?>
            </td>
        <?php endif; ?>

        <td class="col qty" data-th="<?= $block->escapeHtml(__('Qty')) ?>">
            <div class="field qty">
                <div class="control qty fashionstore-qty-control">
                    <button type="button"
                            class="fashionstore-qty-button fashionstore-qty-button--decrement"
                            data-qty-action="decrement"
                            data-target="#cart-<?= $block->escapeHtmlAttr($_item->getId()) ?>-qty"
                            aria-label="<?= $block->escapeHtmlAttr(__('Decrease quantity')) ?>">
                        <span>-</span>
                    </button>
                    <label for="cart-<?= $block->escapeHtmlAttr($_item->getId()) ?>-qty">
                        <span class="label"><?= $block->escapeHtml(__('Qty')) ?></span>
                        <input id="cart-<?= $block->escapeHtmlAttr($_item->getId()) ?>-qty"
                               name="cart[<?= $block->escapeHtmlAttr($_item->getId()) ?>][qty]"
                               data-cart-item-id="<?= $block->escapeHtmlAttr($_item->getSku()) ?>"
                               value="<?= $block->escapeHtmlAttr((string) (float) $qtyValue) ?>"
                               type="number"
                               min="1"
                               size="4"
                               step="1"
                               inputmode="numeric"
                               title="<?= $block->escapeHtmlAttr(__('Qty')) ?>"
                               class="input-text qty"
                               data-validate="{required:true,'validate-greater-than-zero':true,'validate-number':true}"
                               data-item-qty="<?= $block->escapeHtmlAttr($block->getQty()) ?>"
                               data-role="cart-item-qty"/>
                    </label>
                    <button type="button"
                            class="fashionstore-qty-button fashionstore-qty-button--increment"
                            data-qty-action="increment"
                            data-target="#cart-<?= $block->escapeHtmlAttr($_item->getId()) ?>-qty"
                            aria-label="<?= $block->escapeHtmlAttr(__('Increase quantity')) ?>">
                        <span>+</span>
                    </button>
                </div>
            </div>
        </td>

        <td class="col subtotal" data-th="<?= $block->escapeHtml(__('Subtotal')) ?>">
            <?php if ($canApplyMsrp): ?>
                <span class="cart msrp subtotal">--</span>
            <?php else: ?>
                <?= $block->getRowTotalHtml($_item) ?>
            <?php endif; ?>
        </td>
    </tr>
    <tr class="item-actions">
        <td colspan="4">
            <div class="actions-toolbar">
                <?= /* @noEscape */ $block->getActions($_item) ?>
            </div>
        </td>
    </tr>
</tbody>

<script>
if (!window.fashionstoreCartQtyButtonsInitialized) {
    window.fashionstoreCartQtyButtonsInitialized = true;
    document.addEventListener('click', function (event) {
        var button = event.target.closest('[data-qty-action]');
        var input;
        var currentValue;
        var nextValue;

        if (!button) {
            return;
        }

        input = document.querySelector(button.getAttribute('data-target'));
        if (!input) {
            return;
        }

        currentValue = parseInt(input.value || '1', 10);
        if (isNaN(currentValue) || currentValue < 1) {
            currentValue = 1;
        }

        nextValue = button.getAttribute('data-qty-action') === 'increment'
            ? currentValue + 1
            : Math.max(1, currentValue - 1);

        input.value = String(nextValue);
        input.dispatchEvent(new Event('change', { bubbles: true }));
        input.dispatchEvent(new Event('input', { bubbles: true }));
    });
}
</script>