    <script>
    if (!window.fashionstoreCartQtyButtonsInitialized) {
        window.fashionstoreCartQtyButtonsInitialized = true;

        (function () {
            var autoUpdateTimer = null;

            function normalizeValue(input) {
                var currentValue = parseInt(input.value || '1', 10);

                if (isNaN(currentValue) || currentValue < 1) {
                    currentValue = 1;
                }

                input.value = String(currentValue);
                return currentValue;
            }

            function scheduleCartUpdate() {
                var form = document.getElementById('form-validate');
                var actionContainer = document.getElementById('update_cart_action_container');

                if (!form || !actionContainer) {
                    return;
                }

                if (autoUpdateTimer) {
                    window.clearTimeout(autoUpdateTimer);
                }

                autoUpdateTimer = window.setTimeout(function () {
                    actionContainer.value = 'update_qty';
                    form.dispatchEvent(new Event('submit', {
                        bubbles: true,
                        cancelable: true
                    }));
                }, 450);
            }

            function updateInput(input, action) {
                var currentValue = normalizeValue(input);
                var nextValue = action === 'increment'
                    ? currentValue + 1
                    : Math.max(1, currentValue - 1);

                input.value = String(nextValue);
                input.dispatchEvent(new Event('change', { bubbles: true }));
                input.dispatchEvent(new Event('input', { bubbles: true }));
                scheduleCartUpdate();
            }

            function createButton(action, targetId, symbol, label) {
                var button = document.createElement('button');
                var span = document.createElement('span');

                button.type = 'button';
                button.className = 'fashionstore-qty-button fashionstore-qty-button--' + action;
                button.setAttribute('data-qty-action', action);
                button.setAttribute('data-target', '#' + targetId);
                button.setAttribute('aria-label', label);

                span.textContent = symbol;
                button.appendChild(span);

                return button;
            }

            function enhanceQtyControls() {
                document.querySelectorAll('.checkout-cart-index .control.qty').forEach(function (control, index) {
                    var input = control.querySelector('input.qty');
                    var label;
                    var wrapper;
                    var inputId;

                    if (!input || control.getAttribute('data-fashionstore-qty-enhanced') === 'true') {
                        return;
                    }

                    label = control.querySelector('label');
                    inputId = input.id || ('fashionstore-cart-qty-' + index);
                    input.id = inputId;

                    wrapper = document.createElement('div');
                    wrapper.className = 'fashionstore-qty-enhanced';
                    wrapper.appendChild(createButton('decrement', inputId, '-', 'Decrease quantity'));
                    if (label) {
                        wrapper.appendChild(label);
                    } else {
                        wrapper.appendChild(input);
                    }
                    wrapper.appendChild(createButton('increment', inputId, '+', 'Increase quantity'));

                    control.textContent = '';
                    control.appendChild(wrapper);
                    control.setAttribute('data-fashionstore-qty-enhanced', 'true');
                    normalizeValue(input);
                });
            }

            enhanceQtyControls();

            if (!window.fashionstoreCartQtyObserverInitialized) {
                window.fashionstoreCartQtyObserverInitialized = true;

                new MutationObserver(function () {
                    enhanceQtyControls();
                }).observe(document.body, {
                    childList: true,
                    subtree: true
                });
            }

            document.addEventListener('click', function (event) {
                var button = event.target.closest('[data-qty-action]');
                var input;

                if (!button) {
                    return;
                }

                input = document.querySelector(button.getAttribute('data-target'));
                if (!input) {
                    return;
                }

                updateInput(input, button.getAttribute('data-qty-action'));
            });

            document.addEventListener('change', function (event) {
                var input = event.target.closest('.checkout-cart-index input.qty');

                if (!input) {
                    return;
                }

                normalizeValue(input);
                scheduleCartUpdate();
            });
        }());
    }
    </script>

    <script>
    (function () {
        function getTotalsData() {
            if (!window.checkoutConfig || !window.checkoutConfig.totalsData) {
                return null;
            }

            return window.checkoutConfig.totalsData;
        }

        function formatVnd(amount) {
            var normalized = Number(amount || 0);

            if (!isFinite(normalized)) {
                normalized = 0;
            }

            return new Intl.NumberFormat('vi-VN').format(Math.round(normalized)) + ' đ';
        }

        function ensureGrandTotalValue() {
            var totalsRoot = document.getElementById('cart-totals');
            var totalsData = getTotalsData();
            var grandTotal;
            var tableBody;
            var grandRow;
            var priceNode;

            if (!totalsRoot || !totalsData) {
                return;
            }

            grandTotal = totalsData.grand_total;
            if (typeof grandTotal === 'undefined' || grandTotal === null) {
                grandTotal = totalsData.base_grand_total;
            }

            if (typeof grandTotal === 'undefined' || grandTotal === null) {
                return;
            }

            tableBody = totalsRoot.querySelector('table.totals tbody');
            if (!tableBody) {
                return;
            }

            grandRow = tableBody.querySelector('tr.grand.totals');
            if (!grandRow) {
                grandRow = document.createElement('tr');
                grandRow.className = 'grand totals';
                grandRow.innerHTML = '<th class="mark" scope="row"><strong>Tổng thanh toán</strong></th>' +
                    '<td class="amount"><strong><span class="price"></span></strong></td>';
                tableBody.appendChild(grandRow);
            }

            priceNode = grandRow.querySelector('.amount .price');
            if (!priceNode) {
                return;
            }

            if (!String(priceNode.textContent || '').trim()) {
                priceNode.textContent = formatVnd(grandTotal);
            }
        }

        function boot() {
            ensureGrandTotalValue();
            window.setTimeout(ensureGrandTotalValue, 500);
            window.setTimeout(ensureGrandTotalValue, 1400);
        }

        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', boot);
        } else {
            boot();
        }
    }());
    </script>
<?php endif; ?>