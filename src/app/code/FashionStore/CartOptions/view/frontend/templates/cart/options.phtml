    <script>
    if (!window.fashionstoreCartQtyButtonsInitialized) {
        window.fashionstoreCartQtyButtonsInitialized = true;

        (function () {
            var autoUpdateTimer = null;

            function normalizeValue(input) {
                var currentValue = parseInt(input.value || '1', 10);

                if (isNaN(currentValue) || currentValue < 1) {
                    currentValue = 1;
                }

                input.value = String(currentValue);
                return currentValue;
            }

            function scheduleCartUpdate() {
                var form = document.getElementById('form-validate');
                var actionContainer = document.getElementById('update_cart_action_container');

                if (!form || !actionContainer) {
                    return;
                }

                if (autoUpdateTimer) {
                    window.clearTimeout(autoUpdateTimer);
                }

                autoUpdateTimer = window.setTimeout(function () {
                    actionContainer.value = 'update_qty';
                    form.dispatchEvent(new Event('submit', {
                        bubbles: true,
                        cancelable: true
                    }));
                }, 450);
            }

            function updateInput(input, action) {
                var currentValue = normalizeValue(input);
                var nextValue = action === 'increment'
                    ? currentValue + 1
                    : Math.max(1, currentValue - 1);

                input.value = String(nextValue);
                input.dispatchEvent(new Event('change', { bubbles: true }));
                input.dispatchEvent(new Event('input', { bubbles: true }));
                scheduleCartUpdate();
            }

            function createButton(action, targetId, symbol, label) {
                var button = document.createElement('button');
                var span = document.createElement('span');

                button.type = 'button';
                button.className = 'fashionstore-qty-button fashionstore-qty-button--' + action;
                button.setAttribute('data-qty-action', action);
                button.setAttribute('data-target', '#' + targetId);
                button.setAttribute('aria-label', label);

                span.textContent = symbol;
                button.appendChild(span);

                return button;
            }

            function enhanceQtyControls() {
                document.querySelectorAll('.checkout-cart-index .control.qty').forEach(function (control, index) {
                    var input = control.querySelector('input.qty');
                    var label;
                    var wrapper;
                    var inputId;

                    if (!input || control.getAttribute('data-fashionstore-qty-enhanced') === 'true') {
                        return;
                    }

                    label = control.querySelector('label');
                    inputId = input.id || ('fashionstore-cart-qty-' + index);
                    input.id = inputId;

                    wrapper = document.createElement('div');
                    wrapper.className = 'fashionstore-qty-enhanced';
                    wrapper.appendChild(createButton('decrement', inputId, '-', 'Decrease quantity'));
                    if (label) {
                        wrapper.appendChild(label);
                    } else {
                        wrapper.appendChild(input);
                    }
                    wrapper.appendChild(createButton('increment', inputId, '+', 'Increase quantity'));

                    control.textContent = '';
                    control.appendChild(wrapper);
                    control.setAttribute('data-fashionstore-qty-enhanced', 'true');
                    normalizeValue(input);
                });
            }

            enhanceQtyControls();

            document.addEventListener('click', function (event) {
                var button = event.target.closest('[data-qty-action]');
                var input;

                if (!button) {
                    return;
                }

                input = document.querySelector(button.getAttribute('data-target'));
                if (!input) {
                    return;
                }

                updateInput(input, button.getAttribute('data-qty-action'));
            });

            document.addEventListener('change', function (event) {
                var input = event.target.closest('.checkout-cart-index input.qty');

                if (!input) {
                    return;
                }

                normalizeValue(input);
                scheduleCartUpdate();
            });
        }());
    }
    </script>

    <script>
    (function () {
        var numberFormatter = new Intl.NumberFormat('vi-VN', {
            minimumFractionDigits: 2,
            maximumFractionDigits: 2
        });

        function formatVnd(amount) {
            var normalized = Number(amount || 0);

            if (!isFinite(normalized)) {
                normalized = 0;
            }

            return numberFormatter.format(normalized) + ' đ';
        }

        function parseMoney(text) {
            var normalized = String(text || '').trim();

            if (!normalized) {
                return 0;
            }

            normalized = normalized.replace(/\u00a0/g, ' ').replace(/[^0-9,.-]/g, '');

            if (normalized.indexOf(',') !== -1 && normalized.indexOf('.') !== -1) {
                normalized = normalized.replace(/\./g, '').replace(',', '.');
            } else if (normalized.indexOf(',') !== -1) {
                normalized = normalized.replace(',', '.');
            }

            var parsed = parseFloat(normalized);
            return isNaN(parsed) ? 0 : parsed;
        }

        function getItemSubtotal(checkbox) {
            var row = checkbox.closest('tbody.cart.item');
            var subtotalCell = row ? row.querySelector('.col.subtotal') : null;
            var priceNode = subtotalCell ? subtotalCell.querySelector('.price') : null;
            var subtotalText = priceNode ? priceNode.textContent : (subtotalCell ? subtotalCell.textContent : '');

            return parseMoney(subtotalText);
        }

        function getTotalRows() {
            var totalsRoot = document.getElementById('cart-totals');
            var summaryRoot = document.querySelector('.checkout-cart-index .cart-summary');
            var table;
            var tableBody;
            var grandRow;

            if (!totalsRoot && summaryRoot) {
                totalsRoot = document.createElement('div');
                totalsRoot.id = 'cart-totals';
                totalsRoot.className = 'cart-totals';

                table = document.createElement('table');
                table.className = 'data table totals';
                table.innerHTML = '<tbody></tbody>';
                totalsRoot.appendChild(table);

                summaryRoot.insertBefore(totalsRoot, summaryRoot.querySelector('.checkout.methods.items'));
            }

            tableBody = totalsRoot ? totalsRoot.querySelector('table.totals tbody') : null;
            if (!tableBody && totalsRoot) {
                table = document.createElement('table');
                table.className = 'data table totals';
                table.innerHTML = '<tbody></tbody>';
                totalsRoot.appendChild(table);
                tableBody = table.querySelector('tbody');
            }

            if (tableBody) {
                tableBody.querySelectorAll('tr.totals.sub').forEach(function (row) {
                    row.remove();
                });
            }

            grandRow = tableBody ? tableBody.querySelector('tr.grand.totals') : null;
            if (!grandRow && tableBody) {
                grandRow = document.createElement('tr');
                grandRow.className = 'grand totals';
                grandRow.innerHTML = '<th class="mark" scope="row"><strong>Tổng thanh toán</strong></th>' +
                    '<td class="amount"><strong><span class="price">0,00 đ</span></strong></td>';
                tableBody.appendChild(grandRow);
            }

            return {
                grandRow: grandRow
            };
        }

        function setRowAmount(row, amount) {
            var amountNode;
            var priceNode;

            if (!row) {
                return;
            }

            amountNode = row.querySelector('.amount');
            if (!amountNode) {
                amountNode = document.createElement('td');
                amountNode.className = 'amount';
                row.appendChild(amountNode);
            }

            priceNode = amountNode.querySelector('.price');
            if (!priceNode) {
                priceNode = document.createElement('span');
                priceNode.className = 'price';
                amountNode.textContent = '';
                amountNode.appendChild(priceNode);
            }

            if (!priceNode) {
                return;
            }

            priceNode.textContent = formatVnd(amount);
            priceNode.style.color = row.classList.contains('grand') ? '#d2232a' : '#1a1a1a';
            priceNode.style.opacity = '1';
            priceNode.style.visibility = 'visible';
        }

        function getItemCheckboxes() {
            return Array.prototype.slice.call(document.querySelectorAll('.checkout-cart-index .fashionstore-item-select__checkbox'));
        }

        function getCheckedItemsTotal() {
            return getItemCheckboxes().reduce(function (total, checkbox) {
                if (!checkbox.checked) {
                    return total;
                }

                return total + getItemSubtotal(checkbox);
            }, 0);
        }

        function getAllCheckboxState() {
            var checkboxes = getItemCheckboxes();
            var checkedCount = checkboxes.filter(function (checkbox) {
                return checkbox.checked;
            }).length;

            return {
                total: checkboxes.length,
                checked: checkedCount,
                allChecked: checkboxes.length > 0 && checkedCount === checkboxes.length,
                someChecked: checkedCount > 0 && checkedCount < checkboxes.length
            };
        }

        function updateSelectAllState() {
            var state = getAllCheckboxState();
            var selectAll = document.querySelector('.checkout-cart-index .fashionstore-select-all__checkbox');

            if (!selectAll) {
                return;
            }

            selectAll.checked = state.allChecked;
            selectAll.indeterminate = state.someChecked;
        }

        function updateTotalsBySelection() {
            var rows = getTotalRows();
            var selectedTotal = getCheckedItemsTotal();

            setRowAmount(rows.grandRow, selectedTotal);
            updateSelectAllState();
        }

        function injectSelectAllCheckbox() {
            var itemHeader = document.querySelector('.checkout-cart-index #shopping-cart-table thead .col.item');
            var wrapper;
            var checkbox;
            var label;

            if (!itemHeader || itemHeader.querySelector('.fashionstore-select-all')) {
                return;
            }

            wrapper = document.createElement('div');
            wrapper.className = 'fashionstore-select-all';

            checkbox = document.createElement('input');
            checkbox.type = 'checkbox';
            checkbox.className = 'fashionstore-select-all__checkbox';
            checkbox.setAttribute('aria-label', 'Chọn tất cả sản phẩm');

            label = document.createElement('span');
            label.className = 'fashionstore-select-all__label';
            label.textContent = 'Chọn tất cả';

            wrapper.appendChild(checkbox);
            wrapper.appendChild(label);
            itemHeader.insertBefore(wrapper, itemHeader.firstChild);

            checkbox.addEventListener('change', function () {
                getItemCheckboxes().forEach(function (itemCheckbox) {
                    itemCheckbox.checked = checkbox.checked;
                });
                updateTotalsBySelection();
            });
        }

        function bindSelectionEvents() {
            document.addEventListener('change', function (event) {
                if (!event.target.matches('.checkout-cart-index .fashionstore-item-select__checkbox')) {
                    return;
                }

                updateTotalsBySelection();
            });
        }

        function localizeCartLabels() {
            var title = document.querySelector('.checkout-cart-index .page-title span');
            var checkoutSpan = document.querySelector('.checkout-cart-index .checkout.methods.items .action.primary.checkout span');
            var updateCartButtons = document.querySelectorAll('.checkout-cart-index .cart.main.actions .action');

            if (title && /shopping\s*cart/i.test(String(title.textContent || ''))) {
                title.textContent = 'Giỏ hàng';
            }

            if (checkoutSpan && /proceed\s*to\s*checkout/i.test(String(checkoutSpan.textContent || ''))) {
                checkoutSpan.textContent = 'TIẾN HÀNH THANH TOÁN';
            }

            updateCartButtons.forEach(function (button) {
                var text = String(button.textContent || '');

                if (/update\s*shopping\s*cart/i.test(text)) {
                    button.textContent = 'Cập nhật giỏ hàng';
                }
            });
        }

        function syncSelectionToForm() {
            var cartOptionsForm = document.getElementById('fashionstore-cart-options-form');
            var hiddenField = cartOptionsForm ? cartOptionsForm.querySelector('[data-role="checkout-selection"]') : null;

            if (!hiddenField) {
                return;
            }

            var selectedItems = getItemCheckboxes()
                .filter(function (cb) { return cb.checked; })
                .map(function (cb) { return { item_id: parseInt(cb.value, 10) }; })
                .filter(function (item) { return !isNaN(item.item_id) && item.item_id > 0; });

            hiddenField.value = JSON.stringify(selectedItems);
        }

        function boot() {
            injectSelectAllCheckbox();
            bindSelectionEvents();
            localizeCartLabels();
            updateTotalsBySelection();

            window.setTimeout(updateTotalsBySelection, 250);
            window.setTimeout(updateTotalsBySelection, 800);
            window.setTimeout(localizeCartLabels, 250);

            var cartOptionsForm = document.getElementById('fashionstore-cart-options-form');
            if (cartOptionsForm) {
                cartOptionsForm.addEventListener('submit', syncSelectionToForm);
            }
        }

        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', boot);
        } else {
            boot();
        }
    }());
    </script>
<script>
(function () {
    function enableCheckoutButton() {
        var btn = document.querySelector(
            '.checkout.methods.items .action.primary.checkout'
        );
        var checkboxes = document.querySelectorAll(
            '.fashionstore-item-select__checkbox'
        );
        var label = btn ? btn.querySelector('span') : null;
        var checkedCount = 0;

        checkboxes.forEach(function (cb) {
            if (cb.checked) { checkedCount++; }
        });

        if (!btn) { return; }

        if (label) {
            label.textContent = 'Mua hàng (' + checkedCount + ')';
        }

        if (checkboxes.length === 0 || checkedCount > 0) {
            btn.disabled = false;
            btn.removeAttribute('disabled');
        } else {
            btn.disabled = true;
            btn.setAttribute('disabled', 'disabled');
        }
    }

    // Bind checkbox change event
    document.addEventListener('change', function (e) {
        if (e.target && e.target.classList.contains('fashionstore-item-select__checkbox')) {
            enableCheckoutButton();
        }
        if (e.target && e.target.classList.contains('fashionstore-select-all__checkbox')) {
            enableCheckoutButton();
        }
    });

    // Run on load
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', enableCheckoutButton);
    } else {
        enableCheckoutButton();
    }

    // Retry sau khi JS khac co the da disable lai
    setTimeout(enableCheckoutButton, 300);
    setTimeout(enableCheckoutButton, 800);
    setTimeout(enableCheckoutButton, 1500);
}());
</script>
<?php endif; ?>
