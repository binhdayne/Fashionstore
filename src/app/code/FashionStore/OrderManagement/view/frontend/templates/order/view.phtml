<div id="fs-cancel-modal-view" class="fs-modal" style="display:none;">
    <div class="fs-modal__overlay" onclick="FsOrderView.closeCancelModal()"></div>
    <div class="fs-modal__box">
        <div class="fs-modal__header">
            <h3 class="fs-modal__title">Hủy đơn hàng <span id="fs-view-cancel-number"></span></h3>
            <button type="button" class="fs-modal__close" onclick="FsOrderView.closeCancelModal()">X</button>
        </div>
        <div class="fs-modal__body">
            <p class="fs-modal__desc">Vui lòng chọn lý do hủy:</p>
            <div class="fs-cancel-reasons">
                <?php foreach ([
                    'Thay đổi địa chỉ giao hàng',
