                    'Đặt nhầm sản phẩm',
                    'Đặt trùng đơn hàng',
                    'Lý do khác',
                ] as $reason): ?>
                    <label class="fs-cancel-reason">
                        <input type="radio" name="cancel_reason_view"
                               value="<?= $block->escapeHtmlAttr($reason) ?>"/>
                        <span><?= $block->escapeHtml($reason) ?></span>
                    </label>
                <?php endforeach; ?>
            </div>
        </div>
        <div class="fs-modal__footer">
            <button type="button" class="fs-order-btn fs-order-btn--secondary"
                    onclick="FsOrderView.closeCancelModal()">Quay lại</button>
            <button type="button" id="fs-view-confirm-cancel"
                    class="fs-order-btn fs-order-btn--cancel"
                    onclick="FsOrderView.confirmCancel()">Xác nhận hủy</button>
        </div>
    </div>
</div>

<script>
var FsOrderView = (function () {
    'use strict';
    var currentOrderId = null;
    var cancelUrl = '<?= $block->escapeJs($block->getCancelUrl()) ?>';
    var formKey = '<?= $block->escapeJs($block->getFormKey()) ?>';

    function openCancelModal(orderId, orderNumber) {
        currentOrderId = orderId;
        document.getElementById('fs-view-cancel-number').textContent = '#' + orderNumber;
        document.querySelectorAll('#fs-cancel-modal-view input[name="cancel_reason_view"]')
            .forEach(function (radio) { radio.checked = false; });
        document.getElementById('fs-cancel-modal-view').style.display = 'flex';
    }

    function closeCancelModal() {
        currentOrderId = null;
        document.getElementById('fs-cancel-modal-view').style.display = 'none';
    }

    function confirmCancel() {
        var selected = document.querySelector('#fs-cancel-modal-view input[name="cancel_reason_view"]:checked');
        if (!selected) {
            alert('Vui lòng chọn lý do hủy.');
            return;
        }

        var btn = document.getElementById('fs-view-confirm-cancel');
        btn.disabled = true;
        btn.textContent = 'Đang xử lý...';

        var fd = new FormData();
        fd.append('order_id', currentOrderId);
        fd.append('reason', selected.value);
        fd.append('form_key', formKey);

        fetch(cancelUrl, { method: 'POST', body: fd, credentials: 'same-origin' })
            .then(function (response) { return response.json(); })
            .then(function (data) {
                closeCancelModal();
                alert(data.message || (data.success ? 'Đã hủy đơn hàng.' : 'Có lỗi xảy ra.'));
                if (data.success) {
                    window.location.href = '<?= $block->escapeJs($block->getBackUrl()) ?>';
                }
            })
            .catch(function () { alert('Có lỗi xảy ra. Vui lòng thử lại.'); })
            .finally(function () {
                btn.disabled = false;
                btn.textContent = 'Xác nhận hủy';
            });
    }

    return {
        openCancelModal: openCancelModal,
        closeCancelModal: closeCancelModal,
        confirmCancel: confirmCancel
    };
}());
</script>
