                    </label>
                <?php endforeach; ?>
            </div>
        </div>
        <div class="fs-modal__footer">
            <button type="button" class="fs-order-btn fs-order-btn--secondary" onclick="FsOrderHistory.closeCancelModal()">
                <?= $block->escapeHtml(__('Quay lại')) ?>
            </button>
            <button type="button" id="fs-confirm-cancel-btn" class="fs-order-btn fs-order-btn--cancel" onclick="FsOrderHistory.confirmCancel()">
                <?= $block->escapeHtml(__('Xác nhận hủy')) ?>
            </button>
        </div>
    </div>
</div>

<script>
var FsOrderHistory = (function () {
    'use strict';

    var currentOrderId = null;
    var cancelUrl = '<?= $block->escapeJs($cancelUrl) ?>';
    var formKey = '<?= $block->escapeJs($formKey) ?>';

    function openCancelModal(orderId, orderNumber) {
        currentOrderId = orderId;
        document.getElementById('fs-cancel-order-number').textContent = '#' + orderNumber;
        document.querySelectorAll('#fs-cancel-modal input[name="cancel_reason"]').forEach(function (radio) {
            radio.checked = false;
        });
        document.getElementById('fs-cancel-modal').style.display = 'flex';
    }

    function closeCancelModal() {
        currentOrderId = null;
        document.getElementById('fs-cancel-modal').style.display = 'none';
    }

    function confirmCancel() {
        var selected = document.querySelector('#fs-cancel-modal input[name="cancel_reason"]:checked');
        if (!selected) {
            alert('Vui lòng chọn lý do hủy đơn hàng.');
            return;
        }

        var btn = document.getElementById('fs-confirm-cancel-btn');
        btn.disabled = true;
        btn.textContent = 'Đang xử lý...';

        var formData = new FormData();
        formData.append('order_id', currentOrderId);
        formData.append('reason', selected.value);
        formData.append('form_key', formKey);

        fetch(cancelUrl, {
            method: 'POST',
            body: formData,
            credentials: 'same-origin'
        })
        .then(function (response) { return response.json(); })
        .then(function (data) {
            closeCancelModal();
            alert(data.message || 'Đã xử lý yêu cầu.');
            if (data.success) {
                window.location.reload();
            }
        })
        .catch(function () {
            alert('Có lỗi xảy ra. Vui lòng thử lại.');
        })
        .finally(function () {
            btn.disabled = false;
            btn.textContent = 'Xác nhận hủy';
        });
    }

    return {
        openCancelModal: openCancelModal,
        closeCancelModal: closeCancelModal,
        confirmCancel: confirmCancel
    };
}());
 </script>
