            <?= $block->escapeHtml(__('Không có đơn hàng nào.')) ?>
        </p>

        <script>
        (function () {
            'use strict';

            var tabs = document.querySelectorAll('.fs-order-tab');
            var cards = document.querySelectorAll('.fs-order-card');
            var list = document.querySelector('.fs-order-list');
            var noResult = document.getElementById('fs-no-orders-msg');

            function filterOrders(tabKey) {
                var visibleCards = [];

                cards.forEach(function (card) {
                    var state = card.getAttribute('data-state') || '';
                    var status = card.getAttribute('data-status') || '';
                    var show = false;

                    if (tabKey === 'pending' && (status === 'pending' || state === 'new')) {
                        show = true;
                    } else if (tabKey === 'processing' && state === 'processing') {
                        show = true;
                    } else if (tabKey === 'complete' && state === 'complete') {
                        show = true;
                    } else if (tabKey === 'canceled' && state === 'canceled') {
                        show = true;
                    }

                    card.style.display = show ? '' : 'none';
                    if (show) {
                        visibleCards.push(card);
                    }
                });

                if (noResult) {
                    noResult.style.display = visibleCards.length === 0 ? 'block' : 'none';
                }

                if (list) {
                    list.style.display = visibleCards.length === 0 ? 'none' : '';
                }
            }

            tabs.forEach(function (tab) {
                tab.addEventListener('click', function () {
                    tabs.forEach(function (item) {
                        item.classList.remove('is-active');
                    });
                    tab.classList.add('is-active');
                    filterOrders(tab.getAttribute('data-tab'));
                });
            });

            filterOrders('pending');
        }());
        </script>
