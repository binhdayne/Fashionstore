<div id="fs-cancel-modal" class="fs-modal" style="display:none;">
    <div class="fs-modal__overlay" onclick="FsOrderHistory.closeCancelModal()"></div>
    <div class="fs-modal__box">
        <div class="fs-modal__header">
            <h3 class="fs-modal__title"><?= $block->escapeHtml(__('Hủy đơn hàng')) ?> <span id="fs-cancel-order-number"></span></h3>
            <button type="button" class="fs-modal__close" onclick="FsOrderHistory.closeCancelModal()">✕</button>
        </div>
        <div class="fs-modal__body">
            <p class="fs-modal__desc"><?= $block->escapeHtml(__('Vui lòng chọn lý do hủy đơn hàng:')) ?></p>
            <div class="fs-cancel-reasons">
                <?php
                $reasons = [
                    'Thay đổi địa chỉ giao hàng',
                    'Đổi ý, không muốn mua nữa',
                    'Tìm được giá tốt hơn ở nơi khác',
                    'Đặt nhầm sản phẩm',
                    'Đặt trùng đơn hàng',
